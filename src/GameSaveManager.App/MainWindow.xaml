<Window x:Class="GameSaveManager.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="GameSave Manager" Width="1440" Height="900" MinWidth="1100" MinHeight="700"
        WindowStartupLocation="CenterScreen" Background="#070C13" FontFamily="Segoe UI">
    <Window.Resources>
        <SolidColorBrush x:Key="Panel" Color="#0E1927" />
        <SolidColorBrush x:Key="Text" Color="#F4F8FF" />
        <SolidColorBrush x:Key="Muted" Color="#96A8C0" />
        <SolidColorBrush x:Key="Blue" Color="#287DFF" />
        <Style x:Key="PanelStyle" TargetType="Border"><Setter Property="Background" Value="{StaticResource Panel}"/><Setter Property="BorderBrush" Value="#20324A"/><Setter Property="BorderThickness" Value="1"/><Setter Property="CornerRadius" Value="14"/></Style>
        <Style x:Key="ButtonStyle" TargetType="Button"><Setter Property="Height" Value="40"/><Setter Property="Padding" Value="16,0"/><Setter Property="Foreground" Value="White"/><Setter Property="Background" Value="#17263A"/><Setter Property="BorderBrush" Value="#2B405B"/><Setter Property="BorderThickness" Value="1"/><Setter Property="Cursor" Value="Hand"/><Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Button"><Border x:Name="root" CornerRadius="8" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"><ContentPresenter Margin="{TemplateBinding Padding}" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="root" Property="Background" Value="#25456C"/></Trigger><Trigger Property="IsPressed" Value="True"><Setter TargetName="root" Property="Opacity" Value=".78"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Setter.Value></Setter></Style>
        <Style x:Key="Primary" TargetType="Button" BasedOn="{StaticResource ButtonStyle}"><Setter Property="Background" Value="#287DFF"/><Setter Property="BorderBrush" Value="#4894FF"/><Setter Property="FontWeight" Value="SemiBold"/></Style>
        <Style x:Key="Nav" TargetType="Button" BasedOn="{StaticResource ButtonStyle}"><Setter Property="Height" Value="48"/><Setter Property="Margin" Value="0,4"/><Setter Property="HorizontalContentAlignment" Value="Left"/><Setter Property="Foreground" Value="#C5D1E2"/><Setter Property="Background" Value="Transparent"/><Setter Property="BorderBrush" Value="Transparent"/></Style>
        <Style x:Key="Input" TargetType="TextBox"><Setter Property="Height" Value="40"/><Setter Property="Padding" Value="12,0"/><Setter Property="VerticalContentAlignment" Value="Center"/><Setter Property="Foreground" Value="White"/><Setter Property="CaretBrush" Value="White"/><Setter Property="Background" Value="#0A121D"/><Setter Property="BorderBrush" Value="#2A3B53"/><Setter Property="BorderThickness" Value="1"/></Style>
    </Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions><ColumnDefinition Width="250"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
        <Border Background="#05090F" BorderBrush="#1D2A3D" BorderThickness="0,0,1,0">
            <Grid Margin="22,26,18,24"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="28"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                <StackPanel Orientation="Horizontal"><Border Width="48" Height="48" CornerRadius="14" Background="#102C4B" BorderBrush="#287DFF" BorderThickness="1"><TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="25" Foreground="#58CBFF" Text="✦"/></Border><StackPanel Margin="12,0,0,0" VerticalAlignment="Center"><TextBlock FontSize="22" FontWeight="Bold" Foreground="{StaticResource Text}" Text="GameSave"/><TextBlock FontSize="17" FontWeight="SemiBold" Foreground="{StaticResource Text}" Text="Manager"/></StackPanel></StackPanel>
                <StackPanel Grid.Row="2">
                    <Button Style="{StaticResource Nav}" Background="#123C70" BorderBrush="#287DFF" Command="{Binding NavigateCommand}" CommandParameter="首页"><StackPanel Orientation="Horizontal"><TextBlock Width="34" FontSize="20" Text="⌂"/><TextBlock VerticalAlignment="Center" Text="首页"/></StackPanel></Button>
                    <Button Style="{StaticResource Nav}" Command="{Binding NavigateCommand}" CommandParameter="游戏库"><StackPanel Orientation="Horizontal"><TextBlock Width="34" FontSize="20" Text="⌘"/><TextBlock VerticalAlignment="Center" Text="游戏库"/></StackPanel></Button>
                    <Button Style="{StaticResource Nav}" Command="{Binding NavigateCommand}" CommandParameter="时间线"><StackPanel Orientation="Horizontal"><TextBlock Width="34" FontSize="20" Text="◷"/><TextBlock VerticalAlignment="Center" Text="时间线"/></StackPanel></Button>
                    <Button Style="{StaticResource Nav}" Command="{Binding NavigateCommand}" CommandParameter="同步中心"><StackPanel Orientation="Horizontal"><TextBlock Width="34" FontSize="20" Text="↻"/><TextBlock VerticalAlignment="Center" Text="同步中心"/></StackPanel></Button>
                    <Button Style="{StaticResource Nav}" Command="{Binding NavigateCommand}" CommandParameter="设备"><StackPanel Orientation="Horizontal"><TextBlock Width="34" FontSize="20" Text="▣"/><TextBlock VerticalAlignment="Center" Text="设备"/></StackPanel></Button>
                    <Button Style="{StaticResource Nav}" Command="{Binding NavigateCommand}" CommandParameter="设置"><StackPanel Orientation="Horizontal"><TextBlock Width="34" FontSize="20" Text="⚙"/><TextBlock VerticalAlignment="Center" Text="设置"/></StackPanel></Button>
                    <Button Style="{StaticResource Nav}" Command="{Binding NavigateCommand}" CommandParameter="使用说明"><StackPanel Orientation="Horizontal"><TextBlock Width="34" FontSize="20" Text="?"/><TextBlock VerticalAlignment="Center" Text="使用说明"/></StackPanel></Button>
                </StackPanel>
                <Border Grid.Row="3" Padding="14" Style="{StaticResource PanelStyle}"><StackPanel><TextBlock Foreground="{StaticResource Muted}" FontSize="12" Text="本地存储"/><TextBlock Margin="0,6,0,0" Foreground="White" FontWeight="SemiBold" Text="{Binding QuotaUsageText}" TextTrimming="CharacterEllipsis"/><ProgressBar Margin="0,10,0,0" Height="5" Value="42" Maximum="100" Foreground="#287DFF" Background="#26364B" BorderThickness="0"/></StackPanel></Border>
            </Grid>
        </Border>
        <Grid Grid.Column="1"><Grid.RowDefinitions><RowDefinition Height="88"/><RowDefinition Height="*"/></Grid.RowDefinitions>
            <Border Padding="34,20" BorderBrush="#172536" BorderThickness="0,0,0,1"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="250"/><ColumnDefinition Width="16"/><ColumnDefinition Width="135"/><ColumnDefinition Width="20"/><ColumnDefinition Width="165"/></Grid.ColumnDefinitions><TextBlock VerticalAlignment="Center" Foreground="{StaticResource Muted}" Text="{Binding CurrentPage}" FontSize="15"/><TextBox Grid.Column="1" Style="{StaticResource Input}" Text="{Binding GameSearchText, UpdateSourceTrigger=PropertyChanged}" ToolTip="搜索游戏（后续支持）"/><Button Grid.Column="3" Style="{StaticResource Primary}" Command="{Binding NavigateCommand}" CommandParameter="游戏库" Content="＋ 添加游戏"/><Border Grid.Column="5" Height="40" Padding="13,0" CornerRadius="9" Style="{StaticResource PanelStyle}"><StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Ellipse Width="10" Height="10" Fill="#41D993" Margin="0,0,8,0"/><TextBlock Foreground="White" Text="已连接"/></StackPanel></Border></Grid></Border>
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"><StackPanel Margin="34,26,34,32">
                <Border Height="310" CornerRadius="18" BorderBrush="#284767" BorderThickness="1"><Border.Background><LinearGradientBrush StartPoint="0,0" EndPoint="1,1"><GradientStop Color="#112E4B"/><GradientStop Color="#132239" Offset=".54"/><GradientStop Color="#5E4936" Offset="1"/></LinearGradientBrush></Border.Background><Grid Margin="28"><Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="130"/></Grid.RowDefinitions><StackPanel><TextBlock Foreground="White" FontSize="36" FontWeight="Bold" Text="守护你的每一次冒险"/><TextBlock Margin="0,12,0,0" Foreground="#C1D0E1" FontSize="16" Text="自动备份 · 版本管理 · 跨设备同步"/><TextBlock Margin="0,5,0,0" Foreground="#9DB0C8" Text="让每一份存档，都安全无忧。"/></StackPanel><Border Grid.Row="1" Padding="14" Background="#B30A1421" BorderBrush="#465F7F" BorderThickness="1" CornerRadius="12"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="82"/><ColumnDefinition Width="*"/><ColumnDefinition Width="140"/></Grid.ColumnDefinitions><Border Width="70" Height="94" Background="#29425F" CornerRadius="8"><TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="28" Foreground="#69CFFF" Text="✦"/></Border><StackPanel Grid.Column="1" Margin="14,0" VerticalAlignment="Center"><TextBlock Foreground="White" FontSize="20" FontWeight="SemiBold" Text="{Binding SelectedGame.Name, TargetNullValue=选择一款游戏开始}"/><TextBlock Margin="0,7,0,0" Foreground="#A3B5CB" Text="{Binding SelectedGame.Provider, TargetNullValue=本地优先 · 云端可选}"/><TextBlock Margin="0,8,0,0" Foreground="#41D993" FontWeight="SemiBold" Text="● 云端同步已就绪"/></StackPanel><Button Grid.Column="2" Style="{StaticResource Primary}" VerticalAlignment="Center" Command="{Binding SyncCommand}" Content="管理存档"/></Grid></Border></Grid></Border>
                <DockPanel Margin="0,28,0,14"><TextBlock DockPanel.Dock="Left" Foreground="White" FontSize="20" FontWeight="SemiBold" Text="我的游戏"/><Button DockPanel.Dock="Right" Background="Transparent" BorderThickness="0" Foreground="#65ABFF" Command="{Binding NavigateCommand}" CommandParameter="游戏库" Content="查看全部  ›"/></DockPanel>
                <ItemsControl ItemsSource="{Binding Games}"><ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel><ItemsControl.ItemTemplate><DataTemplate><Border Width="190" Height="205" Margin="0,0,16,18" Style="{StaticResource PanelStyle}"><Grid><Grid.RowDefinitions><RowDefinition Height="110"/><RowDefinition Height="*"/></Grid.RowDefinitions><Border CornerRadius="13,13,0,0"><Border.Background><LinearGradientBrush StartPoint="0,0" EndPoint="1,1"><GradientStop Color="#24527F"/><GradientStop Color="#152236" Offset=".62"/><GradientStop Color="#533C58" Offset="1"/></LinearGradientBrush></Border.Background><TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#D9E9FF" FontSize="24" FontWeight="Bold" Text="{Binding Name}" TextTrimming="CharacterEllipsis"/></Border><StackPanel Grid.Row="1" Margin="13,10"><TextBlock Foreground="White" FontWeight="SemiBold" Text="{Binding Name}" TextTrimming="CharacterEllipsis"/><TextBlock Margin="0,5,0,0" Foreground="#98A9C0" FontSize="12" Text="{Binding Provider}"/><TextBlock Margin="0,7,0,0" Foreground="#41D993" FontSize="12" Text="● 已同步"/></StackPanel></Grid></Border></DataTemplate></ItemsControl.ItemTemplate></ItemsControl>
                <Border Padding="18" Margin="0,0,0,24" Style="{StaticResource PanelStyle}"><DockPanel><StackPanel DockPanel.Dock="Left"><TextBlock Foreground="White" FontSize="18" FontWeight="SemiBold" Text="还没有游戏？"/><TextBlock Margin="0,7,0,0" Foreground="{StaticResource Muted}" Text="先扫描本机 Steam、Epic、GOG 游戏，或手动添加游戏。"/></StackPanel><Button DockPanel.Dock="Right" Style="{StaticResource Primary}" Command="{Binding DiscoverGamesCommand}" Content="扫描本机游戏"/></DockPanel></Border>
                <TextBlock Margin="0,0,0,14" Foreground="White" FontSize="20" FontWeight="SemiBold" Text="使用说明"/>
                <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="28"/><ColumnDefinition Width="*"/><ColumnDefinition Width="28"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><Border Padding="20" Style="{StaticResource PanelStyle}"><StackPanel Orientation="Horizontal"><TextBlock FontSize="42" FontWeight="Bold" Foreground="#3988FF" Text="1"/><StackPanel Margin="18,0,0,0"><TextBlock Foreground="White" FontSize="17" FontWeight="SemiBold" Text="添加游戏"/><TextBlock Margin="0,7,0,0" Foreground="{StaticResource Muted}" TextWrapping="Wrap" Text="扫描或手动添加要保护的游戏。"/></StackPanel></StackPanel></Border><TextBlock Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#3974B3" FontSize="28" Text="›"/><Border Grid.Column="2" Padding="20" Style="{StaticResource PanelStyle}"><StackPanel Orientation="Horizontal"><TextBlock FontSize="42" FontWeight="Bold" Foreground="#54CFCB" Text="2"/><StackPanel Margin="18,0,0,0"><TextBlock Foreground="White" FontSize="17" FontWeight="SemiBold" Text="配置存档路径"/><TextBlock Margin="0,7,0,0" Foreground="{StaticResource Muted}" TextWrapping="Wrap" Text="确认游戏真实使用的存档目录。"/></StackPanel></StackPanel></Border><TextBlock Grid.Column="3" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#3974B3" FontSize="28" Text="›"/><Border Grid.Column="4" Padding="20" Style="{StaticResource PanelStyle}"><StackPanel Orientation="Horizontal"><TextBlock FontSize="42" FontWeight="Bold" Foreground="#887EFF" Text="3"/><StackPanel Margin="18,0,0,0"><TextBlock Foreground="White" FontSize="17" FontWeight="SemiBold" Text="自动同步"/><TextBlock Margin="0,7,0,0" Foreground="{StaticResource Muted}" TextWrapping="Wrap" Text="游戏退出后自动创建安全快照。"/></StackPanel></StackPanel></Border></Grid>
                <Border Margin="0,24,0,0" Padding="15" Style="{StaticResource PanelStyle}"><TextBlock Foreground="#AABBD0" TextWrapping="Wrap" Text="{Binding StatusText}"/></Border>
            </StackPanel></ScrollViewer>
        </Grid>
    </Grid>
</Window>
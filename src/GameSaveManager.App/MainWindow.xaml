<Window x:Class="GameSaveManager.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:GameSaveManager.App.Views"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="GameSave Manager" Width="1440" Height="900" MinWidth="1100" MinHeight="700"
        WindowStartupLocation="CenterScreen" WindowStyle="None" AllowsTransparency="True" Background="Transparent" FontFamily="Segoe UI" ResizeMode="CanResize">
    <shell:WindowChrome.WindowChrome><shell:WindowChrome CaptionHeight="0" ResizeBorderThickness="6" CornerRadius="16"/></shell:WindowChrome.WindowChrome>
    <Window.Resources>
        <Style x:Key="WindowControlButton" TargetType="Button">
            <Setter Property="Width" Value="42"/><Setter Property="Height" Value="32"/>
            <Setter Property="Background" Value="Transparent"/><Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource Muted}"/><Setter Property="FontSize" Value="14"/>
            <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Button"><Border x:Name="root" Background="{TemplateBinding Background}"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="root" Property="Background" Value="{DynamicResource ButtonHover}"/><Setter Property="Foreground" Value="{DynamicResource Text}"/></Trigger><Trigger Property="IsPressed" Value="True"><Setter TargetName="root" Property="Background" Value="{DynamicResource ButtonBackground}"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Setter.Value></Setter>
        </Style>
        <Style x:Key="WindowCloseButton" TargetType="Button" BasedOn="{StaticResource WindowControlButton}"><Style.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Foreground" Value="White"/><Setter Property="Background" Value="#B2394A"/></Trigger><Trigger Property="IsPressed" Value="True"><Setter Property="Background" Value="#872B38"/></Trigger></Style.Triggers></Style>
    </Window.Resources>
    <Border Background="{DynamicResource AppBackground}" CornerRadius="16" BorderBrush="{DynamicResource Border}" BorderThickness="1"><Grid><Grid.RowDefinitions><RowDefinition Height="34"/><RowDefinition Height="*"/></Grid.RowDefinitions><Border Background="{DynamicResource SidebarBackground}" CornerRadius="16,16,0,0" MouseLeftButtonDown="TitleBar_OnMouseLeftButtonDown"><Grid Margin="12,0"><TextBlock VerticalAlignment="Center" Foreground="{DynamicResource Muted}" Text="GameSave Manager"/><StackPanel HorizontalAlignment="Right" Orientation="Horizontal"><Button Style="{StaticResource WindowControlButton}" Click="MinimizeButton_OnClick" Content="—"/><Button Style="{StaticResource WindowControlButton}" Click="MaximizeButton_OnClick" Content="□"/><Button Style="{StaticResource WindowCloseButton}" Click="CloseButton_OnClick" Content="✕"/></StackPanel></Grid></Border><Grid Grid.Row="1"><Grid.ColumnDefinitions><ColumnDefinition Width="250"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
        <Border Background="{DynamicResource SidebarBackground}" BorderBrush="{DynamicResource Border}" BorderThickness="0,0,1,0" CornerRadius="0,0,0,15"><Grid Margin="22,26,18,24"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="28"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
            <StackPanel Orientation="Horizontal"><Border Width="48" Height="48" CornerRadius="14" Background="#102C4B" BorderBrush="{DynamicResource PrimaryBrush}" BorderThickness="1"><TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="25" Foreground="#58CBFF" Text="✦"/></Border><StackPanel Margin="12,0,0,0" VerticalAlignment="Center"><TextBlock FontSize="22" FontWeight="Bold" Foreground="{DynamicResource Text}" Text="GameSave"/><TextBlock FontSize="17" FontWeight="SemiBold" Foreground="{DynamicResource Text}" Text="Manager"/></StackPanel></StackPanel>
            <StackPanel Grid.Row="2">
                <Button Command="{Binding NavigateCommand}" CommandParameter="首页"><Button.Style><Style TargetType="Button" BasedOn="{StaticResource Nav}"><Style.Triggers><DataTrigger Binding="{Binding CurrentPage}" Value="首页"><Setter Property="Background" Value="{DynamicResource NavActive}"/><Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/><Setter Property="Foreground" Value="White"/></DataTrigger></Style.Triggers></Style></Button.Style><StackPanel Orientation="Horizontal"><TextBlock Width="34" FontSize="20" Text="⌂"/><TextBlock VerticalAlignment="Center" Text="首页"/></StackPanel></Button>
                <Button Command="{Binding NavigateCommand}" CommandParameter="游戏库"><Button.Style><Style TargetType="Button" BasedOn="{StaticResource Nav}"><Style.Triggers><DataTrigger Binding="{Binding CurrentPage}" Value="游戏库"><Setter Property="Background" Value="{DynamicResource NavActive}"/><Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/><Setter Property="Foreground" Value="White"/></DataTrigger></Style.Triggers></Style></Button.Style><StackPanel Orientation="Horizontal"><TextBlock Width="34" FontSize="20" Text="⌘"/><TextBlock VerticalAlignment="Center" Text="游戏库"/></StackPanel></Button>
                <Button Command="{Binding NavigateCommand}" CommandParameter="时间线"><Button.Style><Style TargetType="Button" BasedOn="{StaticResource Nav}"><Style.Triggers><DataTrigger Binding="{Binding CurrentPage}" Value="时间线"><Setter Property="Background" Value="{DynamicResource NavActive}"/><Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/><Setter Property="Foreground" Value="White"/></DataTrigger></Style.Triggers></Style></Button.Style><StackPanel Orientation="Horizontal"><TextBlock Width="34" FontSize="20" Text="◷"/><TextBlock VerticalAlignment="Center" Text="时间线"/></StackPanel></Button>

                <Button Command="{Binding NavigateCommand}" CommandParameter="设备"><Button.Style><Style TargetType="Button" BasedOn="{StaticResource Nav}"><Style.Triggers><DataTrigger Binding="{Binding CurrentPage}" Value="设备"><Setter Property="Background" Value="{DynamicResource NavActive}"/><Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/><Setter Property="Foreground" Value="White"/></DataTrigger></Style.Triggers></Style></Button.Style><StackPanel Orientation="Horizontal"><TextBlock Width="34" FontSize="20" Text="▣"/><TextBlock VerticalAlignment="Center" Text="设备"/></StackPanel></Button>
                <Button Command="{Binding NavigateCommand}" CommandParameter="账户"><Button.Style><Style TargetType="Button" BasedOn="{StaticResource Nav}"><Style.Triggers><DataTrigger Binding="{Binding CurrentPage}" Value="账户"><Setter Property="Background" Value="{DynamicResource NavActive}"/><Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/><Setter Property="Foreground" Value="White"/></DataTrigger></Style.Triggers></Style></Button.Style><StackPanel Orientation="Horizontal"><TextBlock Width="34" FontSize="20" Text="◉"/><TextBlock VerticalAlignment="Center" Text="账户"/></StackPanel></Button>                <Button Command="{Binding NavigateCommand}" CommandParameter="设置"><Button.Style><Style TargetType="Button" BasedOn="{StaticResource Nav}"><Style.Triggers><DataTrigger Binding="{Binding CurrentPage}" Value="设置"><Setter Property="Background" Value="{DynamicResource NavActive}"/><Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/><Setter Property="Foreground" Value="White"/></DataTrigger></Style.Triggers></Style></Button.Style><StackPanel Orientation="Horizontal"><TextBlock Width="34" FontSize="20" Text="⚙"/><TextBlock VerticalAlignment="Center" Text="设置"/></StackPanel></Button>
                <Button Command="{Binding NavigateCommand}" CommandParameter="使用说明"><Button.Style><Style TargetType="Button" BasedOn="{StaticResource Nav}"><Style.Triggers><DataTrigger Binding="{Binding CurrentPage}" Value="使用说明"><Setter Property="Background" Value="{DynamicResource NavActive}"/><Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/><Setter Property="Foreground" Value="White"/></DataTrigger></Style.Triggers></Style></Button.Style><StackPanel Orientation="Horizontal"><TextBlock Width="34" FontSize="20" Text="?"/><TextBlock VerticalAlignment="Center" Text="使用说明"/></StackPanel></Button>
            </StackPanel>
            <Border Grid.Row="3" Padding="14" Style="{StaticResource PanelStyle}"><StackPanel><TextBlock Foreground="{DynamicResource Muted}" FontSize="12" Text="本地存储"/><TextBlock Margin="0,6,0,0" Foreground="{DynamicResource Text}" FontWeight="SemiBold" Text="{Binding QuotaUsageText}" TextTrimming="CharacterEllipsis"/></StackPanel></Border>
        </Grid></Border>
        <Grid Grid.Column="1"><Grid.RowDefinitions><RowDefinition Height="88"/><RowDefinition Height="*"/></Grid.RowDefinitions><Border Padding="34,20" BorderBrush="{DynamicResource Border}" BorderThickness="0,0,0,1"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="250"/><ColumnDefinition Width="16"/><ColumnDefinition Width="135"/><ColumnDefinition Width="20"/><ColumnDefinition Width="285"/></Grid.ColumnDefinitions><TextBlock VerticalAlignment="Center" Foreground="{DynamicResource Muted}" Text="{Binding CurrentPage}" FontSize="15"/><TextBox Grid.Column="1" Style="{StaticResource SearchInput}" Text="{Binding GameSearchText, UpdateSourceTrigger=PropertyChanged}" ToolTip="按游戏名称或平台搜索"/><Button Grid.Column="3" Style="{StaticResource Primary}" Click="OpenAddGameWizardButton_OnClick" Content="＋ 添加游戏"/><StackPanel Grid.Column="5" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center"><Button Style="{StaticResource ButtonStyle}" Padding="11,0" Height="40" Margin="0,0,8,0" Command="{Binding NavigateCommand}" CommandParameter="账户"><StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Ellipse Width="10" Height="10" Margin="0,0,8,0"><Ellipse.Style><Style TargetType="Ellipse"><Setter Property="Fill" Value="{DynamicResource Muted}"/><Style.Triggers><DataTrigger Binding="{Binding IsAuthenticated}" Value="True"><Setter Property="Fill" Value="{DynamicResource Success}"/></DataTrigger></Style.Triggers></Style></Ellipse.Style></Ellipse><StackPanel><TextBlock Foreground="{DynamicResource Text}" Text="{Binding ConnectionStatusText}"/><TextBlock Foreground="{DynamicResource Muted}" FontSize="11" Text="{Binding AccountSummaryText}"/></StackPanel></StackPanel></Button><Button Height="40" Style="{StaticResource Primary}" Command="{Binding AccountActionCommand}" Content="{Binding AccountActionText}"/></StackPanel></Grid></Border>
            <Grid Grid.Row="1"><views:HomeView><views:HomeView.Style><Style TargetType="views:HomeView"><Setter Property="Visibility" Value="Collapsed"/><Style.Triggers><DataTrigger Binding="{Binding CurrentPage}" Value="首页"><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers></Style></views:HomeView.Style></views:HomeView><views:LibraryView><views:LibraryView.Style><Style TargetType="views:LibraryView"><Setter Property="Visibility" Value="Collapsed"/><Style.Triggers><DataTrigger Binding="{Binding CurrentPage}" Value="游戏库"><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers></Style></views:LibraryView.Style></views:LibraryView><views:TimelineView><views:TimelineView.Style><Style TargetType="views:TimelineView"><Setter Property="Visibility" Value="Collapsed"/><Style.Triggers><DataTrigger Binding="{Binding CurrentPage}" Value="时间线"><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers></Style></views:TimelineView.Style></views:TimelineView><views:GameDetailView><views:GameDetailView.Style><Style TargetType="views:GameDetailView"><Setter Property="Visibility" Value="Collapsed"/><Style.Triggers><DataTrigger Binding="{Binding CurrentPage}" Value="游戏详情"><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers></Style></views:GameDetailView.Style></views:GameDetailView><views:SyncView><views:SyncView.Style><Style TargetType="views:SyncView"><Setter Property="Visibility" Value="Collapsed"/><Style.Triggers><DataTrigger Binding="{Binding CurrentPage}" Value="同步中心"><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers></Style></views:SyncView.Style></views:SyncView><views:DeviceView><views:DeviceView.Style><Style TargetType="views:DeviceView"><Setter Property="Visibility" Value="Collapsed"/><Style.Triggers><DataTrigger Binding="{Binding CurrentPage}" Value="设备"><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers></Style></views:DeviceView.Style></views:DeviceView><views:AccountView><views:AccountView.Style><Style TargetType="views:AccountView"><Setter Property="Visibility" Value="Collapsed"/><Style.Triggers><DataTrigger Binding="{Binding CurrentPage}" Value="账户"><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers></Style></views:AccountView.Style></views:AccountView><views:SettingsView><views:SettingsView.Style><Style TargetType="views:SettingsView"><Setter Property="Visibility" Value="Collapsed"/><Style.Triggers><DataTrigger Binding="{Binding CurrentPage}" Value="设置"><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers></Style></views:SettingsView.Style></views:SettingsView><views:HelpView><views:HelpView.Style><Style TargetType="views:HelpView"><Setter Property="Visibility" Value="Collapsed"/><Style.Triggers><DataTrigger Binding="{Binding CurrentPage}" Value="使用说明"><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers></Style></views:HelpView.Style></views:HelpView></Grid>
        </Grid>
        <!-- 四条边独立命中，支持左右或上下方向调整窗口大小。 -->
        <Border Grid.RowSpan="2" HorizontalAlignment="Left" Width="8" Background="Transparent" Cursor="SizeWE" Tag="10" MouseLeftButtonDown="ResizeBorder_OnMouseLeftButtonDown"/>
        <Border Grid.RowSpan="2" HorizontalAlignment="Right" Width="8" Background="Transparent" Cursor="SizeWE" Tag="11" MouseLeftButtonDown="ResizeBorder_OnMouseLeftButtonDown"/>
        <Border Grid.RowSpan="2" VerticalAlignment="Top" Height="8" Background="Transparent" Cursor="SizeNS" Tag="12" MouseLeftButtonDown="ResizeBorder_OnMouseLeftButtonDown"/>
        <Border Grid.RowSpan="2" VerticalAlignment="Bottom" Height="8" Background="Transparent" Cursor="SizeNS" Tag="15" MouseLeftButtonDown="ResizeBorder_OnMouseLeftButtonDown"/>    </Grid></Grid></Border>
</Window>

<Window x:Class="GameSaveManager.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:GameSaveManager.App.Views"
        Title="GameSave Manager" Width="1440" Height="900" MinWidth="1100" MinHeight="700"
        WindowStartupLocation="CenterScreen" Background="#070C13" FontFamily="Segoe UI">
    <Window.Resources>
        <SolidColorBrush x:Key="Panel" Color="#0E1927"/><SolidColorBrush x:Key="Text" Color="#F4F8FF"/><SolidColorBrush x:Key="Muted" Color="#96A8C0"/>
        <Style x:Key="PanelStyle" TargetType="Border"><Setter Property="Background" Value="{StaticResource Panel}"/><Setter Property="BorderBrush" Value="#20324A"/><Setter Property="BorderThickness" Value="1"/><Setter Property="CornerRadius" Value="14"/></Style>
        <Style x:Key="ButtonStyle" TargetType="Button"><Setter Property="Height" Value="40"/><Setter Property="Padding" Value="16,0"/><Setter Property="Foreground" Value="White"/><Setter Property="Background" Value="#17263A"/><Setter Property="BorderBrush" Value="#2B405B"/><Setter Property="BorderThickness" Value="1"/><Setter Property="Cursor" Value="Hand"/><Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Button"><Border x:Name="root" CornerRadius="8" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"><ContentPresenter Margin="{TemplateBinding Padding}" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="root" Property="Background" Value="#25456C"/></Trigger><Trigger Property="IsPressed" Value="True"><Setter TargetName="root" Property="Opacity" Value=".78"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Setter.Value></Setter></Style>
        <Style x:Key="Primary" TargetType="Button" BasedOn="{StaticResource ButtonStyle}"><Setter Property="Background" Value="#287DFF"/><Setter Property="BorderBrush" Value="#4894FF"/><Setter Property="FontWeight" Value="SemiBold"/></Style>
        <Style x:Key="Nav" TargetType="Button" BasedOn="{StaticResource ButtonStyle}"><Setter Property="Height" Value="48"/><Setter Property="Margin" Value="0,4"/><Setter Property="HorizontalContentAlignment" Value="Left"/><Setter Property="Foreground" Value="#C5D1E2"/><Setter Property="Background" Value="Transparent"/><Setter Property="BorderBrush" Value="Transparent"/></Style>
        <Style x:Key="Input" TargetType="TextBox"><Setter Property="Height" Value="40"/><Setter Property="Padding" Value="12,0"/><Setter Property="VerticalContentAlignment" Value="Center"/><Setter Property="Foreground" Value="White"/><Setter Property="CaretBrush" Value="White"/><Setter Property="Background" Value="#0A121D"/><Setter Property="BorderBrush" Value="#2A3B53"/><Setter Property="BorderThickness" Value="1"/></Style>
    </Window.Resources>
    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="250"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
        <Border Background="#05090F" BorderBrush="#1D2A3D" BorderThickness="0,0,1,0"><Grid Margin="22,26,18,24"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="28"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
            <StackPanel Orientation="Horizontal"><Border Width="48" Height="48" CornerRadius="14" Background="#102C4B" BorderBrush="#287DFF" BorderThickness="1"><TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="25" Foreground="#58CBFF" Text="✦"/></Border><StackPanel Margin="12,0,0,0" VerticalAlignment="Center"><TextBlock FontSize="22" FontWeight="Bold" Foreground="{StaticResource Text}" Text="GameSave"/><TextBlock FontSize="17" FontWeight="SemiBold" Foreground="{StaticResource Text}" Text="Manager"/></StackPanel></StackPanel>
            <StackPanel Grid.Row="2">
                <Button Command="{Binding NavigateCommand}" CommandParameter="首页"><Button.Style><Style TargetType="Button" BasedOn="{StaticResource Nav}"><Style.Triggers><DataTrigger Binding="{Binding CurrentPage}" Value="首页"><Setter Property="Background" Value="#123C70"/><Setter Property="BorderBrush" Value="#287DFF"/><Setter Property="Foreground" Value="White"/></DataTrigger></Style.Triggers></Style></Button.Style><StackPanel Orientation="Horizontal"><TextBlock Width="34" FontSize="20" Text="⌂"/><TextBlock VerticalAlignment="Center" Text="首页"/></StackPanel></Button>
                <Button Command="{Binding NavigateCommand}" CommandParameter="游戏库"><Button.Style><Style TargetType="Button" BasedOn="{StaticResource Nav}"><Style.Triggers><DataTrigger Binding="{Binding CurrentPage}" Value="游戏库"><Setter Property="Background" Value="#123C70"/><Setter Property="BorderBrush" Value="#287DFF"/><Setter Property="Foreground" Value="White"/></DataTrigger></Style.Triggers></Style></Button.Style><StackPanel Orientation="Horizontal"><TextBlock Width="34" FontSize="20" Text="⌘"/><TextBlock VerticalAlignment="Center" Text="游戏库"/></StackPanel></Button>
                <Button Command="{Binding NavigateCommand}" CommandParameter="时间线"><Button.Style><Style TargetType="Button" BasedOn="{StaticResource Nav}"><Style.Triggers><DataTrigger Binding="{Binding CurrentPage}" Value="时间线"><Setter Property="Background" Value="#123C70"/><Setter Property="BorderBrush" Value="#287DFF"/><Setter Property="Foreground" Value="White"/></DataTrigger></Style.Triggers></Style></Button.Style><StackPanel Orientation="Horizontal"><TextBlock Width="34" FontSize="20" Text="◷"/><TextBlock VerticalAlignment="Center" Text="时间线"/></StackPanel></Button>
                <Button Command="{Binding NavigateCommand}" CommandParameter="同步中心"><Button.Style><Style TargetType="Button" BasedOn="{StaticResource Nav}"><Style.Triggers><DataTrigger Binding="{Binding CurrentPage}" Value="同步中心"><Setter Property="Background" Value="#123C70"/><Setter Property="BorderBrush" Value="#287DFF"/><Setter Property="Foreground" Value="White"/></DataTrigger></Style.Triggers></Style></Button.Style><StackPanel Orientation="Horizontal"><TextBlock Width="34" FontSize="20" Text="↻"/><TextBlock VerticalAlignment="Center" Text="同步中心"/></StackPanel></Button>
                <Button Command="{Binding NavigateCommand}" CommandParameter="设备"><Button.Style><Style TargetType="Button" BasedOn="{StaticResource Nav}"><Style.Triggers><DataTrigger Binding="{Binding CurrentPage}" Value="设备"><Setter Property="Background" Value="#123C70"/><Setter Property="BorderBrush" Value="#287DFF"/><Setter Property="Foreground" Value="White"/></DataTrigger></Style.Triggers></Style></Button.Style><StackPanel Orientation="Horizontal"><TextBlock Width="34" FontSize="20" Text="▣"/><TextBlock VerticalAlignment="Center" Text="设备"/></StackPanel></Button>
                <Button Command="{Binding NavigateCommand}" CommandParameter="设置"><Button.Style><Style TargetType="Button" BasedOn="{StaticResource Nav}"><Style.Triggers><DataTrigger Binding="{Binding CurrentPage}" Value="设置"><Setter Property="Background" Value="#123C70"/><Setter Property="BorderBrush" Value="#287DFF"/><Setter Property="Foreground" Value="White"/></DataTrigger></Style.Triggers></Style></Button.Style><StackPanel Orientation="Horizontal"><TextBlock Width="34" FontSize="20" Text="⚙"/><TextBlock VerticalAlignment="Center" Text="设置"/></StackPanel></Button>
                <Button Command="{Binding NavigateCommand}" CommandParameter="使用说明"><Button.Style><Style TargetType="Button" BasedOn="{StaticResource Nav}"><Style.Triggers><DataTrigger Binding="{Binding CurrentPage}" Value="使用说明"><Setter Property="Background" Value="#123C70"/><Setter Property="BorderBrush" Value="#287DFF"/><Setter Property="Foreground" Value="White"/></DataTrigger></Style.Triggers></Style></Button.Style><StackPanel Orientation="Horizontal"><TextBlock Width="34" FontSize="20" Text="?"/><TextBlock VerticalAlignment="Center" Text="使用说明"/></StackPanel></Button>
            </StackPanel>
            <Border Grid.Row="3" Padding="14" Style="{StaticResource PanelStyle}"><StackPanel><TextBlock Foreground="{StaticResource Muted}" FontSize="12" Text="本地存储"/><TextBlock Margin="0,6,0,0" Foreground="White" FontWeight="SemiBold" Text="{Binding QuotaUsageText}" TextTrimming="CharacterEllipsis"/></StackPanel></Border>
        </Grid></Border>
        <Grid Grid.Column="1"><Grid.RowDefinitions><RowDefinition Height="88"/><RowDefinition Height="*"/></Grid.RowDefinitions><Border Padding="34,20" BorderBrush="#172536" BorderThickness="0,0,0,1"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="250"/><ColumnDefinition Width="16"/><ColumnDefinition Width="135"/><ColumnDefinition Width="20"/><ColumnDefinition Width="165"/></Grid.ColumnDefinitions><TextBlock VerticalAlignment="Center" Foreground="{StaticResource Muted}" Text="{Binding CurrentPage}" FontSize="15"/><TextBox Grid.Column="1" Style="{StaticResource Input}" Text="{Binding GameSearchText, UpdateSourceTrigger=PropertyChanged}" ToolTip="按游戏名称或平台搜索"/><Button Grid.Column="3" Style="{StaticResource Primary}" Command="{Binding NavigateCommand}" CommandParameter="游戏库" Content="＋ 添加游戏"/><Border Grid.Column="5" Height="40" Padding="13,0" CornerRadius="9" Style="{StaticResource PanelStyle}"><StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Ellipse Width="10" Height="10" Fill="#41D993" Margin="0,0,8,0"/><TextBlock Foreground="White" Text="已连接"/></StackPanel></Border></Grid></Border>
            <Grid Grid.Row="1"><views:HomeView><views:HomeView.Style><Style TargetType="views:HomeView"><Setter Property="Visibility" Value="Collapsed"/><Style.Triggers><DataTrigger Binding="{Binding CurrentPage}" Value="首页"><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers></Style></views:HomeView.Style></views:HomeView><views:LibraryView><views:LibraryView.Style><Style TargetType="views:LibraryView"><Setter Property="Visibility" Value="Collapsed"/><Style.Triggers><DataTrigger Binding="{Binding CurrentPage}" Value="游戏库"><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers></Style></views:LibraryView.Style></views:LibraryView><views:TimelineView><views:TimelineView.Style><Style TargetType="views:TimelineView"><Setter Property="Visibility" Value="Collapsed"/><Style.Triggers><DataTrigger Binding="{Binding CurrentPage}" Value="时间线"><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers></Style></views:TimelineView.Style></views:TimelineView><views:SyncView><views:SyncView.Style><Style TargetType="views:SyncView"><Setter Property="Visibility" Value="Collapsed"/><Style.Triggers><DataTrigger Binding="{Binding CurrentPage}" Value="同步中心"><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers></Style></views:SyncView.Style></views:SyncView><views:DeviceView><views:DeviceView.Style><Style TargetType="views:DeviceView"><Setter Property="Visibility" Value="Collapsed"/><Style.Triggers><DataTrigger Binding="{Binding CurrentPage}" Value="设备"><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers></Style></views:DeviceView.Style></views:DeviceView><views:SettingsView><views:SettingsView.Style><Style TargetType="views:SettingsView"><Setter Property="Visibility" Value="Collapsed"/><Style.Triggers><DataTrigger Binding="{Binding CurrentPage}" Value="设置"><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers></Style></views:SettingsView.Style></views:SettingsView><views:HelpView><views:HelpView.Style><Style TargetType="views:HelpView"><Setter Property="Visibility" Value="Collapsed"/><Style.Triggers><DataTrigger Binding="{Binding CurrentPage}" Value="使用说明"><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers></Style></views:HelpView.Style></views:HelpView></Grid>
        </Grid>
    </Grid>
</Window>
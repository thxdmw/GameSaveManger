<Window x:Class="GameSaveManager.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="GameSave Manager V2"
        Width="960"
        Height="640"
        MinWidth="760"
        MinHeight="520"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="24" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="24" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock FontSize="28" FontWeight="SemiBold" Text="GameSave Manager V2" />
            <TextBlock Margin="0,8,0,0" FontSize="14" Text="本地优先的游戏存档版本控制与多设备同步客户端" />
        </StackPanel>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox Height="38"
                     Padding="10,7"
                     VerticalContentAlignment="Center"
                     Text="{Binding SaveDirectory, UpdateSourceTrigger=PropertyChanged}" />
            <Button Grid.Column="2"
                    MinWidth="140"
                    Height="38"
                    Padding="18,0"
                    Command="{Binding BuildManifestCommand}"
                    Content="构建 Manifest" />
        </Grid>

        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="24" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Border Padding="20" BorderBrush="Gray" BorderThickness="1" CornerRadius="6">
                <StackPanel>
                    <TextBlock FontSize="13" Text="文件数量" />
                    <TextBlock Margin="0,8,0,0" FontSize="30" FontWeight="SemiBold" Text="{Binding FileCount}" />
                </StackPanel>
            </Border>
            <Border Grid.Column="2" Padding="20" BorderBrush="Gray" BorderThickness="1" CornerRadius="6">
                <StackPanel>
                    <TextBlock FontSize="13" Text="逻辑存档大小" />
                    <TextBlock Margin="0,8,0,0" FontSize="30" FontWeight="SemiBold" Text="{Binding LogicalSizeText}" />
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="5" Margin="0,24,0,0" Padding="20" BorderBrush="Gray" BorderThickness="1" CornerRadius="6">
            <StackPanel>
                <TextBlock FontSize="15" FontWeight="SemiBold" Text="状态" />
                <TextBlock Margin="0,10,0,0" TextWrapping="Wrap" Text="{Binding StatusText}" />
                <TextBlock Margin="0,24,0,0" TextWrapping="Wrap"
                           Text="当前 V2 已接入完整目录扫描、SHA-256 流式 Hash 和 Hash Cache 契约。FileSystemWatcher 后续只负责 dirty 标记，游戏退出后仍执行完整扫描。" />
            </StackPanel>
        </Border>
    </Grid>
</Window>

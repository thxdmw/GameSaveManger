<Window x:Class="GameSaveManager.App.Views.AddGameWizardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="添加游戏" Width="820" Height="720" MinWidth="700" MinHeight="620"
        WindowStartupLocation="CenterOwner" WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" FontFamily="Segoe UI" ResizeMode="CanResize">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0" ResizeBorderThickness="6" CornerRadius="14"/>
    </shell:WindowChrome.WindowChrome>
    <Window.Resources>
        <Style x:Key="WizardCloseButton" TargetType="Button" BasedOn="{StaticResource ButtonStyle}">
            <Setter Property="Width" Value="44"/><Setter Property="Height" Value="40"/>
            <Setter Property="Background" Value="Transparent"/><Setter Property="BorderThickness" Value="0"/>
            <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
        </Style>
        <Style x:Key="WizardStepPanel" TargetType="Border">
            <Setter Property="Visibility" Value="Collapsed"/>
            <Setter Property="Padding" Value="22"/>
            <Setter Property="Background" Value="{DynamicResource Panel}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="14"/>
        </Style>
    </Window.Resources>
    <Border Background="{DynamicResource AppBackground}" BorderBrush="{DynamicResource Border}" BorderThickness="1" CornerRadius="14">
        <Grid>
            <Grid.RowDefinitions><RowDefinition Height="42"/><RowDefinition Height="*"/></Grid.RowDefinitions>
            <Border Background="{DynamicResource SidebarBackground}" BorderBrush="{DynamicResource Border}" BorderThickness="0,0,0,1"
                    CornerRadius="14,14,0,0" MouseLeftButtonDown="TitleBar_OnMouseLeftButtonDown">
                <Grid Margin="18,0,0,0">
                    <TextBlock VerticalAlignment="Center" Foreground="{DynamicResource Text}" FontWeight="SemiBold"
                               Text="{Binding StepTitle, StringFormat=添加游戏 · {0}}"/>
                    <Button HorizontalAlignment="Right" Style="{StaticResource WizardCloseButton}"
                            Click="CloseButton_OnClick" Content="✕"/>
                </Grid>
            </Border>
            <Grid Grid.Row="1" Margin="26,22,26,24">
                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                <StackPanel>
                    <TextBlock Foreground="{DynamicResource Text}" FontSize="26" FontWeight="Bold" Text="添加游戏"/>
                    <TextBlock Margin="0,7,0,0" Foreground="{DynamicResource Muted}"
                               Text="{Binding Step, StringFormat=第 {0} / 6 步 · 最后一步之前不会创建云端游戏}"/>
                </StackPanel>
                <ScrollViewer Grid.Row="1" Margin="0,20,0,18" VerticalScrollBarVisibility="Auto">
                    <Grid>
                        <Border>
                            <Border.Style><Style TargetType="Border" BasedOn="{StaticResource WizardStepPanel}"><Style.Triggers><DataTrigger Binding="{Binding Step}" Value="1"><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers></Style></Border.Style>
                            <StackPanel>
                                <TextBlock Foreground="{DynamicResource Text}" FontSize="20" FontWeight="SemiBold" Text="选择来源"/>
                                <TextBlock Margin="0,8,0,16" Foreground="{DynamicResource Muted}" Text="扫描平台游戏，或选择本地 EXE/LNK 创建自定义游戏。" TextWrapping="Wrap"/>
                                <WrapPanel>
                                    <Button Margin="0,0,10,10" Style="{StaticResource ButtonStyle}" Command="{Binding Host.DiscoverGamesCommand}" Content="扫描 Steam / Epic / GOG"/>
                                    <Button Margin="0,0,10,10" Style="{StaticResource ButtonStyle}" Click="ChooseLocalGameExecutableButton_OnClick" Content="选择本地 EXE 或快捷方式"/>
                                </WrapPanel>
                                <ComboBox Margin="0,8,0,0" ItemsSource="{Binding Host.DiscoveredGames}" SelectedItem="{Binding Host.SelectedDiscoveredGame}" DisplayMemberPath="Name"/>
                            </StackPanel>
                        </Border>
                        <Border>
                            <Border.Style><Style TargetType="Border" BasedOn="{StaticResource WizardStepPanel}"><Style.Triggers><DataTrigger Binding="{Binding Step}" Value="2"><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers></Style></Border.Style>
                            <StackPanel>
                                <TextBlock Foreground="{DynamicResource Text}" FontSize="20" FontWeight="SemiBold" Text="身份与启动"/>
                                <TextBlock Margin="0,14,0,6" Foreground="{DynamicResource Muted}" Text="游戏名称"/>
                                <TextBox Style="{StaticResource Input}" Text="{Binding Host.NewGameName, UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBlock Margin="0,14,0,6" Foreground="{DynamicResource Muted}" Text="启动入口"/>
                                <TextBlock Foreground="{DynamicResource Text}" Text="{Binding Host.AutoSnapshotExecutablePath}" TextTrimming="CharacterEllipsis" ToolTip="{Binding Host.AutoSnapshotExecutablePath}"/>
                                <TextBlock Margin="0,14,0,6" Foreground="{DynamicResource Muted}" Text="工作目录"/>
                                <TextBox Style="{StaticResource Input}" Text="{Binding WorkingDirectory, UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBlock Margin="0,14,0,6" Foreground="{DynamicResource Muted}" Text="启动参数"/>
                                <TextBox Style="{StaticResource Input}" Text="{Binding Arguments, UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBlock Margin="0,14,0,6" Foreground="{DynamicResource Muted}" Text="监控进程名"/>
                                <TextBox Style="{StaticResource Input}" Text="{Binding MonitoredProcessName, UpdateSourceTrigger=PropertyChanged}"/>
                                <CheckBox Margin="0,14,0,0" Foreground="{DynamicResource Text}" IsChecked="{Binding RunAsAdministrator}" Content="以管理员权限启动"/>
                                <StackPanel Margin="0,16,0,0" Orientation="Horizontal">
                                    <Button Style="{StaticResource Primary}" Click="TestLaunchButton_OnClick" Content="测试启动"/>
                                    <TextBlock Margin="12,0,0,0" VerticalAlignment="Center" Foreground="{DynamicResource Muted}" Text="{Binding LaunchValidationText}"/>
                                </StackPanel>
                                <ItemsControl Margin="0,12,0,0" ItemsSource="{Binding DetectedProcessOptions}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <CheckBox Margin="0,4" Foreground="{DynamicResource Text}"
                                                      IsChecked="{Binding IsSelected}" Content="{Binding ProcessName}"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                        <Border>
                            <Border.Style><Style TargetType="Border" BasedOn="{StaticResource WizardStepPanel}"><Style.Triggers><DataTrigger Binding="{Binding Step}" Value="3"><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers></Style></Border.Style>
                            <StackPanel>
                                <TextBlock Foreground="{DynamicResource Text}" FontSize="20" FontWeight="SemiBold" Text="存档检测"/>
                                <WrapPanel Margin="0,14,0,0">
                                    <Button Margin="0,0,10,10" Style="{StaticResource ButtonStyle}" Command="{Binding Host.SuggestSaveDirectoriesCommand}" Content="自动检测"/>
                                    <Button Margin="0,0,10,10" Style="{StaticResource ButtonStyle}" Click="ChooseSaveDirectoryButton_OnClick" Content="手动选择"/>
                                    <Button Margin="0,0,10,10" Style="{StaticResource ButtonStyle}" Command="{Binding Host.StartSaveLearningCommand}" Content="运行游戏学习"/>
                                </WrapPanel>
                                <ListBox Margin="0,8,0,0" MaxHeight="260" Style="{StaticResource ThemedListBox}"
                                         ItemContainerStyle="{StaticResource ThemedListBoxItem}"
                                         ItemsSource="{Binding Host.SaveLocationCandidates}" SelectedItem="{Binding Host.SelectedSaveLocationCandidate}">
                                    <ListBox.ItemTemplate><DataTemplate><StackPanel Margin="8"><TextBlock Foreground="{DynamicResource Text}" Text="{Binding Path}" TextTrimming="CharacterEllipsis" ToolTip="{Binding Path}"/><TextBlock Foreground="{DynamicResource Muted}" FontSize="12" Text="{Binding Reason}" TextTrimming="CharacterEllipsis" ToolTip="{Binding Reason}"/></StackPanel></DataTemplate></ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>
                        </Border>
                        <Border>
                            <Border.Style><Style TargetType="Border" BasedOn="{StaticResource WizardStepPanel}"><Style.Triggers><DataTrigger Binding="{Binding Step}" Value="4"><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers></Style></Border.Style>
                            <StackPanel>
                                <TextBlock Foreground="{DynamicResource Text}" FontSize="20" FontWeight="SemiBold" Text="预览确认"/>
                                <TextBlock Margin="0,14,0,6" Foreground="{DynamicResource Muted}" Text="存档目录"/>
                                <TextBlock Foreground="{DynamicResource Text}" Text="{Binding Host.SaveDirectory}" TextTrimming="CharacterEllipsis" ToolTip="{Binding Host.SaveDirectory}"/>
                                <StackPanel Margin="0,14,0,0" Orientation="Horizontal">
                                    <Button Style="{StaticResource ButtonStyle}" Command="{Binding Host.PreviewSaveDirectoryCommand}" Content="生成预览"/>
                                    <Button Margin="10,0,0,0" Style="{StaticResource Primary}" Command="{Binding Host.ConfirmSaveDirectoryCommand}" Content="确认目录"/>
                                </StackPanel>
                                <TextBlock Margin="0,14,0,0" Foreground="{DynamicResource Muted}" Text="{Binding Host.SaveDirectoryPreviewText}" TextWrapping="Wrap"/>
                                <TextBlock Margin="0,8,0,0" Foreground="{DynamicResource Warning}" Text="{Binding Host.SaveDirectoryConfirmationText}"/>
                                <ItemsControl Margin="0,12,0,0" ItemsSource="{Binding Host.SaveRootPreviews}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,3" Padding="10" Background="{DynamicResource ItemBackground}" CornerRadius="8">
                                                <StackPanel>
                                                    <TextBlock Foreground="{DynamicResource Text}" Text="{Binding Rule.Path}" TextTrimming="CharacterEllipsis" ToolTip="{Binding Rule.Path}"/>
                                                    <TextBlock Margin="0,4,0,0" Foreground="{DynamicResource Muted}" FontSize="12" Text="{Binding Summary}" TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <ItemsControl Margin="0,8,0,0" ItemsSource="{Binding Host.RegistrySavePreviews}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,3" Padding="10" Background="{DynamicResource ItemBackground}" CornerRadius="8">
                                                <StackPanel>
                                                    <TextBlock Foreground="{DynamicResource Text}" Text="{Binding Rule.KeyPath}" TextTrimming="CharacterEllipsis" ToolTip="{Binding Rule.KeyPath}"/>
                                                    <TextBlock Margin="0,4,0,0" Foreground="{DynamicResource Muted}" FontSize="12" Text="{Binding Summary}" TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                        <Border>
                            <Border.Style><Style TargetType="Border" BasedOn="{StaticResource WizardStepPanel}"><Style.Triggers><DataTrigger Binding="{Binding Step}" Value="5"><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers></Style></Border.Style>
                            <StackPanel>
                                <TextBlock Foreground="{DynamicResource Text}" FontSize="20" FontWeight="SemiBold" Text="保护方式"/>
                                <CheckBox Margin="0,18,0,0" Foreground="{DynamicResource Text}" IsChecked="{Binding EnableAutomaticBackup}" Content="游戏退出后自动备份（未勾选时仅手动备份）"/>
                                <TextBlock Margin="24,8,0,0" Foreground="{DynamicResource Muted}" Text="自动备份仅在启动验证通过、监控进程存在且存档目录已确认时启用。" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                        <Border>
                            <Border.Style><Style TargetType="Border" BasedOn="{StaticResource WizardStepPanel}"><Style.Triggers><DataTrigger Binding="{Binding Step}" Value="6"><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers></Style></Border.Style>
                            <StackPanel>
                                <TextBlock Foreground="{DynamicResource Text}" FontSize="20" FontWeight="SemiBold" Text="最终提交"/>
                                <TextBlock Margin="0,16,0,0" Foreground="{DynamicResource Muted}" Text="游戏名称"/>
                                <TextBlock Margin="0,4,0,0" Foreground="{DynamicResource Text}" FontSize="18" Text="{Binding Host.NewGameName}"/>
                                <TextBlock Margin="0,14,0,0" Foreground="{DynamicResource Muted}" Text="启动验证"/>
                                <TextBlock Margin="0,4,0,0" Foreground="{DynamicResource Text}" Text="{Binding LaunchValidationText}"/>
                                <TextBlock Margin="0,14,0,0" Foreground="{DynamicResource Muted}" Text="存档目录"/>
                                <TextBlock Margin="0,4,0,0" Foreground="{DynamicResource Text}" Text="{Binding Host.SaveDirectory}" TextTrimming="CharacterEllipsis" ToolTip="{Binding Host.SaveDirectory}"/>
                                <TextBlock Margin="0,18,0,0" Foreground="{DynamicResource Warning}" Text="提交顺序：创建云端游戏、保存本地配置、初始化同步状态、按条件启用自动备份。" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </ScrollViewer>
                <Grid Grid.Row="2">
                    <Button HorizontalAlignment="Left" Width="90" Style="{StaticResource ButtonStyle}" Click="PreviousButton_OnClick" Content="上一步"/>
                    <TextBlock Margin="110,0,340,0" VerticalAlignment="Center" HorizontalAlignment="Stretch"
                               Foreground="{DynamicResource Warning}" Text="{Binding StepValidationMessage}"
                               TextWrapping="Wrap" TextTrimming="CharacterEllipsis"/>
                    <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                        <Button Width="90" Margin="0,0,10,0" Style="{StaticResource ButtonStyle}" IsCancel="True" Content="取消"/>
                        <Button Width="100" Click="NextButton_OnClick" Content="下一步" IsEnabled="{Binding CanMoveNext}">
                            <Button.Style><Style TargetType="Button" BasedOn="{StaticResource Primary}"><Style.Triggers><DataTrigger Binding="{Binding Step}" Value="6"><Setter Property="Visibility" Value="Collapsed"/></DataTrigger></Style.Triggers></Style></Button.Style>
                        </Button>
                        <Button Width="120" Command="{Binding Host.CreateGameCommand}" Content="创建并完成">
                            <Button.Style><Style TargetType="Button" BasedOn="{StaticResource Primary}"><Setter Property="Visibility" Value="Collapsed"/><Style.Triggers><DataTrigger Binding="{Binding Step}" Value="6"><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers></Style></Button.Style>
                        </Button>
                    </StackPanel>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>

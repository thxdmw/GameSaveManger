<UserControl x:Class="GameSaveManager.App.Views.DeviceView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
<ScrollViewer VerticalScrollBarVisibility="Auto"><StackPanel Margin="34,28,34,32"><DockPanel><StackPanel DockPanel.Dock="Left"><TextBlock Foreground="{DynamicResource Text}" FontSize="30" FontWeight="Bold" Text="设备与存储"/><TextBlock Margin="0,8,0,24" Foreground="{DynamicResource Muted}" Text="管理当前账号的云端容量和登录设备。"/></StackPanel><StackPanel DockPanel.Dock="Right" Orientation="Horizontal"><Button Style="{StaticResource ButtonStyle}" Margin="0,0,10,0" Command="{Binding ReloadQuotaCommand}" Content="刷新容量"/><Button Style="{StaticResource ButtonStyle}" Command="{Binding ReloadDevicesCommand}" Content="刷新设备"/></StackPanel></DockPanel>
<Border Padding="24" Style="{StaticResource PanelStyle}"><StackPanel><TextBlock Foreground="{DynamicResource Muted}" Text="云端存储空间"/><TextBlock Margin="0,8,0,0" Foreground="{DynamicResource Text}" FontSize="25" FontWeight="SemiBold" Text="{Binding QuotaUsageText}"/><ProgressBar Margin="0,18,0,0" Height="8" Value="42" Maximum="100" Foreground="{DynamicResource PrimaryBrush}" Background="{DynamicResource ScrollTrack}" BorderThickness="0"/></StackPanel></Border>
<TextBlock Margin="0,24,0,12" Foreground="{DynamicResource Text}" FontSize="20" FontWeight="SemiBold" Text="已登录设备"/><Border Padding="12" Style="{StaticResource PanelStyle}"><ListBox ItemsSource="{Binding Devices}" SelectedItem="{Binding SelectedDevice}" Background="Transparent" BorderThickness="0" Foreground="{DynamicResource Text}"><ListBox.ItemTemplate><DataTemplate><Border Padding="12" Margin="0,3" Background="{DynamicResource ItemBackground}" CornerRadius="8"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="190"/></Grid.ColumnDefinitions><TextBlock Foreground="{DynamicResource Text}" Text="{Binding DeviceName}"/><TextBlock Grid.Column="1" HorizontalAlignment="Right" Foreground="{DynamicResource Muted}" Text="{Binding LastSeenTime, StringFormat={}{0:yyyy-MM-dd HH:mm}}"/></Grid></Border></DataTemplate></ListBox.ItemTemplate></ListBox></Border><StackPanel Margin="0,16,0,0" Orientation="Horizontal" HorizontalAlignment="Right"><Button Style="{StaticResource ButtonStyle}" Margin="0,0,10,0" Command="{Binding RevokeDeviceCommand}" Content="撤销所选设备"/><Button Style="{StaticResource Primary}" Command="{Binding NavigateCommand}" CommandParameter="设置" Content="账号设置"/></StackPanel><Border Margin="0,18,0,0" Padding="16" Style="{StaticResource PanelStyle}"><TextBlock Foreground="{DynamicResource Muted}" Text="{Binding StatusText}" TextWrapping="Wrap"/></Border></StackPanel></ScrollViewer>
</UserControl>
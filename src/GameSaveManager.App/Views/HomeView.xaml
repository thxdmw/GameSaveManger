<UserControl x:Class="GameSaveManager.App.Views.HomeView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
<ScrollViewer VerticalScrollBarVisibility="Auto"><StackPanel Margin="34,28,34,32">
<Border Height="370" CornerRadius="18" BorderBrush="{DynamicResource Border}" BorderThickness="1"><Border.Background><LinearGradientBrush StartPoint="0,0" EndPoint="1,1"><GradientStop Color="#112E4B"/><GradientStop Color="#132239" Offset=".55"/><GradientStop Color="#5E4936" Offset="1"/></LinearGradientBrush></Border.Background><Grid Margin="28"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions><StackPanel><TextBlock Foreground="{DynamicResource Text}" FontSize="36" FontWeight="Bold" Text="守护你的每一次冒险"/><TextBlock Margin="0,12,0,0" Foreground="{DynamicResource Muted}" FontSize="16" Text="自动同步 · 版本管理 · 跨设备同步"/><TextBlock Margin="0,5,0,0" Foreground="{DynamicResource Muted}" Text="让每一份存档，都安全无忧。"/></StackPanel><Grid Grid.Row="1" Margin="0,26,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="370"/><ColumnDefinition Width="26"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><Border Padding="16" Background="#C90C1726" BorderBrush="#506D8CAC" BorderThickness="1" CornerRadius="13"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="84"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><Border Width="72" Height="102" Background="#304968" CornerRadius="9"><TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="29" Foreground="{DynamicResource PrimaryBrush}" Text="✦"/></Border><StackPanel Grid.Column="1" Margin="14,0"><TextBlock Foreground="{DynamicResource Text}" FontSize="20" FontWeight="SemiBold" Text="{Binding SelectedGame.Name, TargetNullValue=选择一款游戏}" TextTrimming="CharacterEllipsis"/><TextBlock Margin="0,7,0,0" Foreground="{DynamicResource Muted}" Text="{Binding SelectedGame.Provider, TargetNullValue=云端游戏库}"/><TextBlock Margin="0,9,0,0" Foreground="{DynamicResource Muted}" FontSize="12" Text="在同步中心配置存档路径和同步。"/><Button Margin="0,14,0,0" Width="132" HorizontalAlignment="Left" Style="{StaticResource Primary}" Command="{Binding NavigateCommand}" CommandParameter="同步中心" Content="▣  管理存档"/></StackPanel></Grid></Border><StackPanel Grid.Column="2"><TextBlock Foreground="{DynamicResource Text}" FontWeight="SemiBold" Text="最近快照"/><ItemsControl Margin="0,12,0,0" ItemsSource="{Binding Snapshots}"><ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel><ItemsControl.ItemTemplate><DataTemplate><Border Width="116" Height="82" Padding="9" Margin="0,0,10,0" Background="#C20A121D" BorderBrush="{DynamicResource Border}" BorderThickness="1" CornerRadius="9"><StackPanel><TextBlock Foreground="{DynamicResource Text}" FontSize="12" Text="{Binding CreateTime, StringFormat={}{0:MM/dd HH:mm}}"/><TextBlock Margin="0,7,0,0" Foreground="{DynamicResource Muted}" FontSize="11" Text="{Binding TriggerType}" TextTrimming="CharacterEllipsis"/></StackPanel></Border></DataTemplate></ItemsControl.ItemTemplate></ItemsControl><Grid Margin="0,14,0,0" Height="20"><Border Height="1" VerticalAlignment="Center" Background="#60738BA8"/><ItemsControl ItemsSource="{Binding Snapshots}"><ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel><ItemsControl.ItemTemplate><DataTemplate><Ellipse Width="11" Height="11" Margin="26,4,28,0" Fill="{DynamicResource PrimaryBrush}" Stroke="#9AB8D7" StrokeThickness="1"/></DataTemplate></ItemsControl.ItemTemplate></ItemsControl></Grid><TextBlock Margin="0,9,0,0" Foreground="{DynamicResource Muted}" FontSize="12" Text="首次同步后，快照将以时间线形式显示在这里。"/></StackPanel></Grid></Grid></Border><DockPanel Margin="0,28,0,14"><TextBlock DockPanel.Dock="Left" Foreground="{DynamicResource Text}" FontSize="20" FontWeight="SemiBold" Text="我的游戏"/><Button DockPanel.Dock="Right" Style="{StaticResource LinkButton}" Command="{Binding NavigateCommand}" CommandParameter="游戏库" Content="查看全部  ›"/></DockPanel>
<Grid Height="230"><ItemsControl ItemsSource="{Binding FilteredGames}"><ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel><ItemsControl.ItemTemplate><DataTemplate><Button Width="205" Height="210" Margin="0,0,16,0" Style="{StaticResource GameCardButton}" Command="{Binding DataContext.SelectGameCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}"><Border Style="{StaticResource PanelStyle}"><Grid><Grid.RowDefinitions><RowDefinition Height="122"/><RowDefinition Height="*"/></Grid.RowDefinitions><Border CornerRadius="13,13,0,0"><Border.Background><LinearGradientBrush StartPoint="0,0" EndPoint="1,1"><GradientStop Color="#1A3C60"/><GradientStop Color="#172338" Offset=".6"/><GradientStop Color="#46354B" Offset="1"/></LinearGradientBrush></Border.Background><TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#6CACFF" FontSize="20" FontWeight="Bold" Text="{Binding Name}" TextTrimming="CharacterEllipsis"/></Border><StackPanel Grid.Row="1" Margin="13,11"><TextBlock Foreground="{DynamicResource Text}" FontWeight="SemiBold" Text="{Binding Name}" TextTrimming="CharacterEllipsis"/><TextBlock Margin="0,6,0,0" Foreground="{DynamicResource Muted}" FontSize="12" Text="{Binding Provider}"/><TextBlock Margin="0,8,0,0" Foreground="{DynamicResource Muted}" FontSize="12" Text="点击选择游戏"/></StackPanel></Grid></Border></Button></DataTemplate></ItemsControl.ItemTemplate></ItemsControl><Border Padding="18" Height="160" VerticalAlignment="Top"><Border.Style><Style TargetType="Border" BasedOn="{StaticResource PanelStyle}"><Setter Property="Visibility" Value="Collapsed"/><Style.Triggers><DataTrigger Binding="{Binding HasGames}" Value="False"><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers></Style></Border.Style><DockPanel><StackPanel DockPanel.Dock="Left"><TextBlock Foreground="{DynamicResource Text}" FontSize="18" FontWeight="SemiBold" Text="还没有游戏"/><TextBlock Margin="0,7,0,0" Foreground="{DynamicResource Muted}" Text="扫描本机 Steam、Epic、GOG 游戏，或手动添加游戏。"/></StackPanel><Button DockPanel.Dock="Right" Style="{StaticResource Primary}" Command="{Binding NavigateCommand}" CommandParameter="游戏库" Content="添加游戏"/></DockPanel></Border></Grid>
<TextBlock Margin="0,20,0,14" Foreground="{DynamicResource Text}" FontSize="20" FontWeight="SemiBold" Text="使用说明"/><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="28"/><ColumnDefinition Width="*"/><ColumnDefinition Width="28"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><Border Padding="20" Style="{StaticResource PanelStyle}"><StackPanel Orientation="Horizontal"><TextBlock FontSize="42" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}" Text="1"/><StackPanel Margin="18,0,0,0"><TextBlock Foreground="{DynamicResource Text}" FontSize="17" FontWeight="SemiBold" Text="添加游戏"/><TextBlock Margin="0,7,0,0" Foreground="{DynamicResource Muted}" TextWrapping="Wrap" Text="扫描或手动添加要保护的游戏。"/></StackPanel></StackPanel></Border><TextBlock Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource PrimaryBrush}" FontSize="28" Text="›"/><Border Grid.Column="2" Padding="20" Style="{StaticResource PanelStyle}"><StackPanel Orientation="Horizontal"><TextBlock FontSize="42" FontWeight="Bold" Foreground="#4CCBD2" Text="2"/><StackPanel Margin="18,0,0,0"><TextBlock Foreground="{DynamicResource Text}" FontSize="17" FontWeight="SemiBold" Text="配置存档路径"/><TextBlock Margin="0,7,0,0" Foreground="{DynamicResource Muted}" TextWrapping="Wrap" Text="确认游戏真实使用的存档目录。"/></StackPanel></StackPanel></Border><TextBlock Grid.Column="3" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource PrimaryBrush}" FontSize="28" Text="›"/><Border Grid.Column="4" Padding="20" Style="{StaticResource PanelStyle}"><StackPanel Orientation="Horizontal"><TextBlock FontSize="42" FontWeight="Bold" Foreground="#7A78FF" Text="3"/><StackPanel Margin="18,0,0,0"><TextBlock Foreground="{DynamicResource Text}" FontSize="17" FontWeight="SemiBold" Text="自动同步"/><TextBlock Margin="0,7,0,0" Foreground="{DynamicResource Muted}" TextWrapping="Wrap" Text="游戏退出后自动创建安全快照。"/></StackPanel></StackPanel></Border></Grid>
</StackPanel></ScrollViewer>
</UserControl>
<UserControl x:Class="GameSaveManager.App.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:GameSaveManager.App.Views">
    <UserControl.Resources>
        <local:GameRuntimeStatusConverter x:Key="GameRuntimeStatusConverter"/>
    </UserControl.Resources>

    <Grid Margin="34,28,34,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="370"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" CornerRadius="18" BorderBrush="{DynamicResource Border}" BorderThickness="1" Background="{DynamicResource HeroStart}">
            <Grid Margin="28">
                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                <StackPanel>
                    <TextBlock Foreground="{DynamicResource Text}" FontSize="36" FontWeight="Bold" Text="守护你的每一次冒险"/>
                    <TextBlock Margin="0,12,0,0" Foreground="{DynamicResource Muted}" FontSize="16" Text="自动同步 · 版本管理 · 跨设备同步"/>
                    <TextBlock Margin="0,5,0,0" Foreground="{DynamicResource Muted}" Text="让每一份存档，都安全无忧。"/>
                </StackPanel>
                <Grid Grid.Row="1" Margin="0,26,0,0">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="370"/><ColumnDefinition Width="26"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <Border Padding="16" Background="{DynamicResource Panel}" BorderBrush="{DynamicResource Border}" BorderThickness="1" CornerRadius="13">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="84"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <Border Width="72" Height="102" Background="{DynamicResource ItemBackground}" CornerRadius="9">
                                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="29" Foreground="{DynamicResource PrimaryBrush}" Text="✦"/>
                            </Border>
                            <StackPanel Grid.Column="1" Margin="14,0">
                                <TextBlock Foreground="{DynamicResource Text}" FontSize="20" FontWeight="SemiBold" Text="{Binding SelectedGame.Name, TargetNullValue=选择一款游戏}" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Margin="0,7,0,0" Foreground="{DynamicResource Muted}" Text="{Binding SelectedGame.Provider, TargetNullValue=云端游戏库}"/>
                                <TextBlock Margin="0,9,0,0" Foreground="{DynamicResource Muted}" FontSize="12" Text="在同步中心配置存档路径和同步。"/>
                                <Button Margin="0,14,0,0" Width="132" HorizontalAlignment="Left" Style="{StaticResource Primary}" Command="{Binding NavigateCommand}" CommandParameter="同步中心" Content="▣  管理存档"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <StackPanel Grid.Column="2">
                        <TextBlock Foreground="{DynamicResource Text}" FontWeight="SemiBold" Text="最近快照"/>
                        <ItemsControl Height="82" Margin="0,12,0,0" ClipToBounds="True" ItemsSource="{Binding Snapshots}">
                            <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate><DataTemplate>
                                <Border Width="116" Height="82" Padding="9" Margin="0,0,10,0" Background="{DynamicResource ItemBackground}" BorderBrush="{DynamicResource Border}" BorderThickness="1" CornerRadius="9">
                                    <StackPanel>
                                        <TextBlock Foreground="{DynamicResource Text}" FontSize="12" Text="{Binding CreateTime, StringFormat={}{0:MM/dd HH:mm}}"/>
                                        <TextBlock Margin="0,7,0,0" Foreground="{DynamicResource Muted}" FontSize="11" Text="{Binding TriggerDisplayText}" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate></ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Grid Height="20" Margin="0,14,0,0" ClipToBounds="True">
                            <Border Height="2" Margin="5,0" VerticalAlignment="Center" Background="{DynamicResource TimelineLine}"/>
                            <ItemsControl ItemsSource="{Binding Snapshots}">
                                <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate><DataTemplate>
                                    <Ellipse Width="12" Height="12" Margin="26,4,28,0" Fill="{DynamicResource PrimaryBrush}" Stroke="{DynamicResource TimelineLine}" StrokeThickness="2"/>
                                </DataTemplate></ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                        <TextBlock Margin="0,9,0,0" Foreground="{DynamicResource Muted}" FontSize="12" Text="首次同步后，快照将以时间线形式显示在这里。"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <DockPanel Grid.Row="1" Margin="0,24,0,12">
            <TextBlock DockPanel.Dock="Left" Foreground="{DynamicResource Text}" FontSize="20" FontWeight="SemiBold" Text="我的游戏"/>
            <Button DockPanel.Dock="Right" Style="{StaticResource LinkButton}" Command="{Binding NavigateCommand}" CommandParameter="游戏库" Content="查看全部  ›"/>
        </DockPanel>

        <Grid Grid.Row="2" MinHeight="180">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" PanningMode="VerticalOnly">
                <ItemsControl ItemsSource="{Binding FilteredGames}">
                    <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate><DataTemplate>
                        <Grid Width="205" Height="210" Margin="0,0,16,16">
                            <Border Style="{StaticResource PanelStyle}">
                                <Grid>
                                    <Grid.RowDefinitions><RowDefinition Height="122"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                                    <Border CornerRadius="13,13,0,0">
                                        <Border.Background><LinearGradientBrush StartPoint="0,0" EndPoint="1,1"><GradientStop Color="#1A3C60"/><GradientStop Color="#172338" Offset=".6"/><GradientStop Color="#46354B" Offset="1"/></LinearGradientBrush></Border.Background>
                                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#6CACFF" FontSize="20" FontWeight="Bold" Text="{Binding Name}" TextTrimming="CharacterEllipsis"/>
                                    </Border>
                                    <StackPanel Grid.Row="1" Margin="13,11">
                                        <TextBlock Foreground="{DynamicResource Text}" FontWeight="SemiBold" Text="{Binding Name}" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Margin="0,6,0,0" Foreground="{DynamicResource Muted}" FontSize="12" Text="{Binding Provider}"/>
                                        <TextBlock Margin="0,8,0,0" Foreground="{DynamicResource Muted}" FontSize="12">
                                            <TextBlock.Text><MultiBinding Converter="{StaticResource GameRuntimeStatusConverter}"><Binding/><Binding Path="DataContext" RelativeSource="{RelativeSource AncestorType=UserControl}"/><Binding Path="DataContext.RuntimeStatusVersion" RelativeSource="{RelativeSource AncestorType=UserControl}"/></MultiBinding></TextBlock.Text>
                                        </TextBlock>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <Button Width="62" Height="28" Margin="0,0,12,10" HorizontalAlignment="Right" VerticalAlignment="Bottom" Style="{StaticResource Primary}" Command="{Binding DataContext.LaunchGameCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Content="启动"/>
                        </Grid>
                    </DataTemplate></ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
            <Border Padding="18" Height="160" VerticalAlignment="Top">
                <Border.Style><Style TargetType="Border" BasedOn="{StaticResource PanelStyle}"><Setter Property="Visibility" Value="Collapsed"/><Style.Triggers><DataTrigger Binding="{Binding HasGames}" Value="False"><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers></Style></Border.Style>
                <DockPanel>
                    <StackPanel DockPanel.Dock="Left"><TextBlock Foreground="{DynamicResource Text}" FontSize="18" FontWeight="SemiBold" Text="还没有游戏"/><TextBlock Margin="0,7,0,0" Foreground="{DynamicResource Muted}" Text="扫描本机 Steam、Epic、GOG 游戏，或手动添加游戏。"/></StackPanel>
                    <Button DockPanel.Dock="Right" Style="{StaticResource Primary}" Command="{Binding NavigateCommand}" CommandParameter="游戏库" Content="添加游戏"/>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
<UserControl x:Class="GameSaveManager.App.Views.HomeView"              xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">     <ScrollViewer VerticalScrollBarVisibility="Auto"><StackPanel Margin="34,26,34,32">         <Border Height="310" CornerRadius="18" BorderBrush="{DynamicResource Border}" BorderThickness="1"><Border.Background><LinearGradientBrush StartPoint="0,0" EndPoint="1,1"><GradientStop Color="#112E4B"/><GradientStop Color="#132239" Offset=".54"/><GradientStop Color="#5E4936" Offset="1"/></LinearGradientBrush></Border.Background><Grid Margin="28"><Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="130"/></Grid.RowDefinitions><StackPanel><TextBlock Foreground="{DynamicResource Text}" FontSize="36" FontWeight="Bold" Text="守护你的每一次冒险"/><TextBlock Margin="0,12,0,0" Foreground="{DynamicResource Muted}" FontSize="16" Text="自动备份 · 版本管理 · 跨设备同步"/><TextBlock Margin="0,5,0,0" Foreground="{DynamicResource Muted}" Text="让每一份存档，都安全无忧。"/></StackPanel><Border Grid.Row="1" Padding="14" Background="{DynamicResource ItemBackground}" BorderBrush="{DynamicResource Border}" BorderThickness="1" CornerRadius="12"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="82"/><ColumnDefinition Width="*"/><ColumnDefinition Width="140"/></Grid.ColumnDefinitions><Border Width="70" Height="94" Background="{DynamicResource ItemBackground}" CornerRadius="8"><TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="28" Foreground="{DynamicResource PrimaryBrush}" Text="✦"/></Border><StackPanel Grid.Column="1" Margin="14,0" VerticalAlignment="Center"><TextBlock Foreground="{DynamicResource Text}" FontSize="20" FontWeight="SemiBold" Text="{Binding SelectedGame.Name, TargetNullValue=选择一款游戏开始}"/><TextBlock Margin="0,7,0,0" Foreground="{DynamicResource Muted}" Text="{Binding SelectedGame.Provider, TargetNullValue=本地优先 · 云端可选}"/><TextBlock Margin="0,8,0,0" Foreground="{DynamicResource Muted}" FontWeight="SemiBold" Text="{Binding CloudReadinessText}"/></StackPanel><Button Grid.Column="2" Style="{StaticResource Primary}" VerticalAlignment="Center" Command="{Binding NavigateCommand}" CommandParameter="同步中心" Content="管理存档"/></Grid></Border></Grid></Border>         <DockPanel Margin="0,28,0,14"><TextBlock DockPanel.Dock="Left" Foreground="{DynamicResource Text}" FontSize="20" FontWeight="SemiBold" Text="我的游戏"/><Button DockPanel.Dock="Right" Style="{StaticResource LinkButton}" Command="{Binding NavigateCommand}" CommandParameter="游戏库" Content="查看全部  ›"/></DockPanel>         <ItemsControl ItemsSource="{Binding FilteredGames}"><ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel><ItemsControl.ItemTemplate><DataTemplate><Button Width="190" Height="205" Margin="0,0,16,18" Background="Transparent" BorderThickness="0" Command="{Binding DataContext.SelectGameCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}"><Border Style="{StaticResource PanelStyle}"><Grid><Grid.RowDefinitions><RowDefinition Height="110"/><RowDefinition Height="*"/></Grid.RowDefinitions><Border CornerRadius="13,13,0,0"><Border.Background><LinearGradientBrush StartPoint="0,0" EndPoint="1,1"><GradientStop Color="#24527F"/><GradientStop Color="#152236" Offset=".62"/><GradientStop Color="#533C58" Offset="1"/></LinearGradientBrush></Border.Background><TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource PrimaryBrush}" FontSize="22" FontWeight="Bold" Text="{Binding Name}" TextTrimming="CharacterEllipsis"/></Border><StackPanel Grid.Row="1" Margin="13,10"><TextBlock Foreground="{DynamicResource Text}" FontWeight="SemiBold" Text="{Binding Name}" TextTrimming="CharacterEllipsis"/><TextBlock Margin="0,5,0,0" Foreground="{DynamicResource Muted}" FontSize="12" Text="{Binding Provider}"/><TextBlock Margin="0,7,0,0" Foreground="#41D993" FontSize="12" Text="● 已同步 · 点击管理"/></StackPanel></Grid></Border></Button></DataTemplate></ItemsControl.ItemTemplate></ItemsControl>         <Border Padding="18" Margin="0,0,0,24" Style="{StaticResource PanelStyle}"><DockPanel><StackPanel DockPanel.Dock="Left"><TextBlock Foreground="{DynamicResource Text}" FontSize="18" FontWeight="SemiBold" Text="还没有游戏？"/><TextBlock Margin="0,7,0,0" Foreground="{DynamicResource Muted}" Text="扫描本机 Steam、Epic、GOG 游戏，或手动添加游戏。"/></StackPanel><Button DockPanel.Dock="Right" Style="{StaticResource Primary}" Command="{Binding NavigateCommand}" CommandParameter="游戏库" Content="添加游戏"/></DockPanel></Border>         <TextBlock Margin="0,0,0,14" Foreground="{DynamicResource Text}" FontSize="20" FontWeight="SemiBold" Text="最近快照"/>         <ItemsControl ItemsSource="{Binding Snapshots}"><ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel><ItemsControl.ItemTemplate><DataTemplate><Border Width="220" Padding="14" Margin="0,0,14,18" Style="{StaticResource PanelStyle}"><StackPanel><TextBlock Foreground="{DynamicResource Text}" FontWeight="SemiBold" Text="{Binding Description}" TextTrimming="CharacterEllipsis"/><TextBlock Margin="0,8,0,0" Foreground="{DynamicResource Muted}" FontSize="12" Text="{Binding CreateTime, StringFormat={}{0:yyyy-MM-dd HH:mm}}"/><TextBlock Margin="0,8,0,0" Foreground="{DynamicResource Success}" FontSize="12" Text="{Binding TriggerType}"/></StackPanel></Border></DataTemplate></ItemsControl.ItemTemplate></ItemsControl>         <TextBlock Margin="0,0,0,14" Foreground="{DynamicResource Text}" FontSize="20" FontWeight="SemiBold" Text="使用说明"/>         <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="28"/><ColumnDefinition Width="*"/><ColumnDefinition Width="28"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><Border Padding="20" Style="{StaticResource PanelStyle}"><StackPanel Orientation="Horizontal"><TextBlock FontSize="42" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}" Text="1"/><StackPanel Margin="18,0,0,0"><TextBlock Foreground="{DynamicResource Text}" FontSize="17" FontWeight="SemiBold" Text="添加游戏"/><TextBlock Margin="0,7,0,0" Foreground="{DynamicResource Muted}" TextWrapping="Wrap" Text="扫描或手动添加要保护的游戏。"/></StackPanel></StackPanel></Border><TextBlock Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource PrimaryBrush}" FontSize="28" Text="›"/><Border Grid.Column="2" Padding="20" Style="{StaticResource PanelStyle}"><StackPanel Orientation="Horizontal"><TextBlock FontSize="42" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}" Text="2"/><StackPanel Margin="18,0,0,0"><TextBlock Foreground="{DynamicResource Text}" FontSize="17" FontWeight="SemiBold" Text="配置存档路径"/><TextBlock Margin="0,7,0,0" Foreground="{DynamicResource Muted}" TextWrapping="Wrap" Text="确认游戏真实使用的存档目录。"/></StackPanel></StackPanel></Border><TextBlock Grid.Column="3" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource PrimaryBrush}" FontSize="28" Text="›"/><Border Grid.Column="4" Padding="20" Style="{StaticResource PanelStyle}"><StackPanel Orientation="Horizontal"><TextBlock FontSize="42" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}" Text="3"/><StackPanel Margin="18,0,0,0"><TextBlock Foreground="{DynamicResource Text}" FontSize="17" FontWeight="SemiBold" Text="自动同步"/><TextBlock Margin="0,7,0,0" Foreground="{DynamicResource Muted}" TextWrapping="Wrap" Text="游戏退出后自动创建安全快照。"/></StackPanel></StackPanel></Border></Grid>         <Border Margin="0,24,0,0" Padding="15" Style="{StaticResource PanelStyle}"><TextBlock Foreground="{DynamicResource Muted}" TextWrapping="Wrap" Text="{Binding StatusText}"/></Border>     </StackPanel></ScrollViewer> </UserControl>
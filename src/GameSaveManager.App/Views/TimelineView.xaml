<UserControl x:Class="GameSaveManager.App.Views.TimelineView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
<ScrollViewer VerticalScrollBarVisibility="Auto"><StackPanel Margin="34,28,34,32"><DockPanel><StackPanel DockPanel.Dock="Left"><TextBlock Foreground="{DynamicResource Text}" FontSize="30" FontWeight="Bold" Text="快照时间线"/><TextBlock Margin="0,8,0,24" Foreground="{DynamicResource Muted}" Text="快照不可覆盖；恢复前会创建当前存档的安全备份。"/></StackPanel><Button DockPanel.Dock="Right" Style="{StaticResource ButtonStyle}" Command="{Binding ReloadSnapshotsCommand}" Content="刷新时间线"/></DockPanel>
<Border Padding="16" Style="{StaticResource PanelStyle}"><ListBox ItemsSource="{Binding Snapshots}" SelectedItem="{Binding SelectedSnapshot}" Background="Transparent" BorderThickness="0" Foreground="{DynamicResource Text}"><ListBox.ItemTemplate><DataTemplate><Border Padding="14" Margin="0,4" Background="{DynamicResource ItemBackground}" CornerRadius="9"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="180"/><ColumnDefinition Width="*"/><ColumnDefinition Width="140"/></Grid.ColumnDefinitions><TextBlock Foreground="{DynamicResource Muted}" Text="{Binding CreateTime, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}"/><StackPanel Grid.Column="1"><TextBlock Foreground="{DynamicResource Text}" FontWeight="SemiBold" Text="{Binding Description}"/><TextBlock Margin="0,5,0,0" Foreground="{DynamicResource Muted}" FontSize="12" Text="{Binding TriggerType}"/></StackPanel><TextBlock Grid.Column="2" HorizontalAlignment="Right" Foreground="{DynamicResource Success}" Text="{Binding ChangedFileCount, StringFormat=变更 {0} 个文件}"/></Grid></Border></DataTemplate></ListBox.ItemTemplate></ListBox></Border>
<StackPanel Margin="0,18,0,0" HorizontalAlignment="Right" Orientation="Horizontal"><Button Style="{StaticResource ButtonStyle}" Margin="0,0,10,0" Command="{Binding DeleteSnapshotCommand}" Content="删除历史快照"/><Button Style="{StaticResource ButtonStyle}" Margin="0,0,10,0" Command="{Binding KeepLocalConflictCommand}" Content="冲突时保留本机版本"/><Button Style="{StaticResource Primary}" Command="{Binding RestoreCommand}" Content="恢复所选快照"/></StackPanel>
<Border Margin="0,18,0,0" Padding="16" Style="{StaticResource PanelStyle}"><TextBlock Foreground="{DynamicResource Muted}" Text="{Binding StatusText}" TextWrapping="Wrap"/></Border></StackPanel></ScrollViewer>
</UserControl>
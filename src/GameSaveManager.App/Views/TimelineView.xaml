<UserControl x:Class="GameSaveManager.App.Views.TimelineView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="34,28,34,32">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left"><TextBlock Foreground="{DynamicResource Text}" FontSize="30" FontWeight="Bold" Text="快照时间线"/><TextBlock Margin="0,8,0,24" Foreground="{DynamicResource Muted}" Text="快照不可覆盖；恢复前会创建当前存档的安全备份。"/></StackPanel>
                <Button DockPanel.Dock="Right" Style="{StaticResource ButtonStyle}" Command="{Binding ReloadSnapshotsCommand}" Content="刷新时间线"/>
            </DockPanel>
            <Border Padding="16" Style="{StaticResource PanelStyle}">
                <ListBox ItemsSource="{Binding Snapshots}" SelectedItem="{Binding SelectedSnapshot}" Background="Transparent" BorderThickness="0" Foreground="{DynamicResource Text}">
                    <ListBox.ItemTemplate><DataTemplate><Border Padding="14" Margin="0,4" Background="{DynamicResource ItemBackground}" CornerRadius="9"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="180"/><ColumnDefinition Width="*"/><ColumnDefinition Width="140"/></Grid.ColumnDefinitions><TextBlock Foreground="{DynamicResource Muted}" Text="{Binding LocalCreateTime, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}"/><StackPanel Grid.Column="1"><TextBlock Foreground="{DynamicResource Text}" FontWeight="SemiBold" Text="{Binding Description}"/><TextBlock Margin="0,5,0,0" Foreground="{DynamicResource Muted}" FontSize="12" Text="{Binding TriggerDisplayText}"/><TextBlock Margin="0,5,12,0" Foreground="{DynamicResource Muted}" FontSize="11" Text="{Binding RootSummaryText}" TextWrapping="Wrap"/></StackPanel><TextBlock Grid.Column="2" HorizontalAlignment="Right" Foreground="{DynamicResource Success}" Text="{Binding ChangedFileCount, StringFormat=变更 {0} 个文件}"/></Grid></Border></DataTemplate></ListBox.ItemTemplate>
                </ListBox>
            </Border>
            <Border Margin="0,18,0,0" Padding="16" Style="{StaticResource PanelStyle}"><StackPanel><TextBlock Foreground="{DynamicResource Text}" FontWeight="SemiBold" Text="恢复预览"/><TextBlock Margin="0,8,0,0" Foreground="{DynamicResource Muted}" Text="{Binding RestorePreviewText}" TextWrapping="Wrap"/></StackPanel></Border>
            <WrapPanel Margin="0,18,0,0" HorizontalAlignment="Right"><Button Style="{StaticResource ButtonStyle}" Margin="0,0,10,8" Command="{Binding LoadRestorePreviewCommand}" Content="查看恢复内容"/><Button Style="{StaticResource ButtonStyle}" Margin="0,0,10,8" Command="{Binding ExportSnapshotCommand}" Content="导出 ZIP"/><Button Style="{StaticResource ButtonStyle}" Margin="0,0,10,8" Click="DeleteSnapshotButton_OnClick" Content="删除历史快照"/><Button Style="{StaticResource ButtonStyle}" Margin="0,0,10,8" Click="KeepLocalButton_OnClick" IsEnabled="{Binding HasActiveConflict}" Content="冲突时保留本机版本"/><Button Style="{StaticResource Primary}" Margin="0,0,0,8" Click="RestoreButton_OnClick" Content="恢复所选快照"/></WrapPanel>
            <Border Margin="0,18,0,0" Padding="16" Style="{StaticResource PanelStyle}"><TextBlock Foreground="{DynamicResource Muted}" Text="{Binding StatusText}" TextWrapping="Wrap"/></Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>

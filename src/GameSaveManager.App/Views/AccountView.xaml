<UserControl x:Class="GameSaveManager.App.Views.AccountView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto"><StackPanel Margin="34,28,34,32">
        <TextBlock Foreground="{DynamicResource Text}" FontSize="30" FontWeight="Bold" Text="账户"/>
        <TextBlock Margin="0,8,0,24" Foreground="{DynamicResource Muted}" Text="登录、注册和管理当前 GameSave 账户。设备信息由客户端自动生成，无需手动填写。"/>
        <Border Padding="24" Style="{StaticResource PanelStyle}">
            <Grid>
            <Grid><Grid.Style><Style TargetType="Grid"><Setter Property="Visibility" Value="Visible"/><Style.Triggers><DataTrigger Binding="{Binding IsAuthenticated}" Value="True"><Setter Property="Visibility" Value="Collapsed"/></DataTrigger></Style.Triggers></Style></Grid.Style><StackPanel>
                <TextBlock Foreground="{DynamicResource Text}" FontSize="18" FontWeight="SemiBold" Text="登录或注册"/>
                <TextBlock Margin="0,10,0,0" Foreground="{DynamicResource Muted}" Text="账号和密码属于 GameSave 云端账户；注册后可直接使用同一组信息登录其他电脑。" TextWrapping="Wrap"/>
                <TextBlock Margin="0,18,0,7" Foreground="{DynamicResource Muted}" Text="服务端地址"/><TextBox Style="{StaticResource Input}" Text="{Binding ServerAddress, UpdateSourceTrigger=PropertyChanged}" ToolTip="例如 https://gamesave.example.com"/>
                <Grid Margin="0,14,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="12"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><StackPanel><TextBlock Margin="0,0,0,7" Foreground="{DynamicResource Muted}" Text="账号"/><TextBox Style="{StaticResource Input}" Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" ToolTip="输入账号"/></StackPanel><StackPanel Grid.Column="2"><TextBlock Margin="0,0,0,7" Foreground="{DynamicResource Muted}" Text="密码（至少 8 位）"/><PasswordBox x:Name="PasswordInput" Height="40" Padding="12,0" VerticalContentAlignment="Center" Foreground="{DynamicResource Text}" PasswordChanged="PasswordBox_OnPasswordChanged" ToolTip="输入密码"/></StackPanel></Grid>
                <StackPanel Margin="0,18,0,0" Orientation="Horizontal" HorizontalAlignment="Right"><Button Style="{StaticResource ButtonStyle}" Margin="0,0,10,0" Command="{Binding RegisterCommand}" Content="注册"/><Button Style="{StaticResource Primary}" Command="{Binding LoginCommand}" Content="登录"/></StackPanel>
            </StackPanel></Grid>
            <Grid><Grid.Style><Style TargetType="Grid"><Setter Property="Visibility" Value="Collapsed"/><Style.Triggers><DataTrigger Binding="{Binding IsAuthenticated}" Value="True"><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers></Style></Grid.Style><StackPanel>
                <TextBlock Foreground="{DynamicResource Text}" FontSize="18" FontWeight="SemiBold" Text="已登录"/>
                <TextBlock Margin="0,14,0,0" Foreground="{DynamicResource Muted}" Text="账号"/><TextBlock Margin="0,4,0,0" Foreground="{DynamicResource Text}" FontSize="22" FontWeight="SemiBold" Text="{Binding AuthenticatedUsername}"/>
                <TextBlock Margin="0,16,0,0" Foreground="{DynamicResource Muted}" Text="连接的服务端"/><TextBlock Margin="0,4,0,0" Foreground="{DynamicResource Text}" Text="{Binding ServerAddress}"/>
                <TextBlock Margin="0,18,0,0" Foreground="{DynamicResource Muted}" Text="退出登录只会清除本机的设备 Token，不会删除云端游戏、云端存档或本地存档文件。" TextWrapping="Wrap"/>
                <Button Margin="0,18,0,0" HorizontalAlignment="Left" Style="{StaticResource ButtonStyle}" Command="{Binding LogoutCommand}" Content="退出登录"/>
            </StackPanel></Grid>
            </Grid>
        </Border>
        <Border Margin="0,18,0,0" Padding="16" Style="{StaticResource PanelStyle}"><TextBlock Foreground="{DynamicResource Muted}" Text="{Binding StatusText}" TextWrapping="Wrap"/></Border>
    </StackPanel></ScrollViewer>
</UserControl>
<Window x:Class="GameSaveManager.App.Views.ConflictResolutionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="处理同步冲突" Width="620" Height="460" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner" Background="{DynamicResource AppBackground}">
    <Grid Margin="26">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <StackPanel>
            <TextBlock Foreground="{DynamicResource Text}" FontSize="25" FontWeight="Bold" Text="检测到多设备版本冲突"/>
            <TextBlock Margin="0,8,0,0" Foreground="{DynamicResource Muted}"
                       Text="上传已停止，未修改本机和云端内容。请选择明确的处理方式。" TextWrapping="Wrap"/>
        </StackPanel>
        <Grid Grid.Row="1" Margin="0,22,0,18">
            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="14"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <Border Padding="18" Style="{StaticResource PanelStyle}">
                <StackPanel>
                    <TextBlock Foreground="{DynamicResource Text}" FontWeight="SemiBold" Text="本机版本"/>
                    <TextBlock Margin="0,10,0,0" Foreground="{DynamicResource Muted}" Text="{Binding FileCount, StringFormat=文件数量：{0}}"/>
                    <TextBlock Margin="0,5,0,0" Foreground="{DynamicResource Muted}" Text="{Binding LogicalSizeText, StringFormat=逻辑大小：{0}}"/>
                    <TextBlock Margin="0,5,0,0" Foreground="{DynamicResource Muted}" Text="{Binding SelectedGameLastSyncText}" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="2" Padding="18" Style="{StaticResource PanelStyle}">
                <StackPanel>
                    <TextBlock Foreground="{DynamicResource Text}" FontWeight="SemiBold" Text="当前云端 HEAD"/>
                    <TextBlock Margin="0,10,0,0" Foreground="{DynamicResource Muted}" Text="{Binding SelectedSnapshot.LocalCreateTime, StringFormat=时间：{0:yyyy-MM-dd HH:mm}}"/>
                    <TextBlock Margin="0,5,0,0" Foreground="{DynamicResource Muted}" Text="{Binding SelectedSnapshot.DeviceId, StringFormat=设备：{0}}"/>
                    <TextBlock Margin="0,5,0,0" Foreground="{DynamicResource Muted}" Text="{Binding SelectedSnapshot.FileCount, StringFormat=文件数量：{0}}"/>
                    <TextBlock Margin="0,5,0,0" Foreground="{DynamicResource Muted}" Text="{Binding SelectedSnapshot.LogicalSize, StringFormat=逻辑字节：{0}}"/>
                </StackPanel>
            </Border>
        </Grid>
        <StackPanel Grid.Row="2" HorizontalAlignment="Right" Orientation="Horizontal">
            <Button Margin="0,0,10,0" Style="{StaticResource ButtonStyle}" IsCancel="True" Content="取消"/>
            <Button Margin="0,0,10,0" Style="{StaticResource ButtonStyle}" Click="RestoreRemote_OnClick" Content="恢复云端版本"
                    ToolTip="恢复前会创建本机安全备份"/>
            <Button Style="{StaticResource Primary}" Click="KeepLocal_OnClick" Content="保留本机并创建新版本"
                    ToolTip="不会删除旧云端版本"/>
        </StackPanel>
    </Grid>
</Window>

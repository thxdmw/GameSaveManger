<UserControl x:Class="GameSaveManager.App.Views.SyncView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="34,28,34,32">
            <TextBlock Foreground="{DynamicResource Text}" FontSize="30" FontWeight="Bold" Text="同步中心"/>
            <TextBlock Margin="0,8,0,24" Foreground="{DynamicResource Muted}" Text="同步前先比较本机与云端 HEAD；内容按 Hash 增量上传，冲突不会静默覆盖。"/>
            <Border Padding="24" Style="{StaticResource PanelStyle}">
                <StackPanel>
                    <TextBlock Foreground="{DynamicResource Text}" FontSize="18" FontWeight="SemiBold" Text="手动同步"/>
                    <TextBlock Margin="0,18,0,7" Foreground="{DynamicResource Muted}" Text="当前游戏"/>
                    <ComboBox Height="40" Padding="10,4" ItemsSource="{Binding Games}" SelectedItem="{Binding SelectedGame}" DisplayMemberPath="Name" SelectionChanged="GameSelection_OnSelectionChanged"/>
                    <TextBlock Margin="0,18,0,7" Foreground="{DynamicResource Muted}" Text="存档目录"/>
                    <Grid>
    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="10"/><ColumnDefinition Width="110"/><ColumnDefinition Width="10"/><ColumnDefinition Width="145"/></Grid.ColumnDefinitions>
    <TextBox Style="{StaticResource Input}" Text="{Binding SaveDirectory, UpdateSourceTrigger=PropertyChanged}"/>
    <Button Grid.Column="2" Style="{StaticResource ButtonStyle}" Click="ChooseSaveDirectoryButton_OnClick" Content="选择目录"/>
    <Button Grid.Column="4" Style="{StaticResource ButtonStyle}" Command="{Binding SuggestSaveDirectoriesCommand}" Content="查找常见目录"/>
</Grid>
<ListBox Margin="0,10,0,0" MinHeight="122" MaxHeight="300" Padding="6" Background="{DynamicResource InputBackground}" BorderBrush="{DynamicResource Border}" BorderThickness="1" Foreground="{DynamicResource Text}" ItemsSource="{Binding SaveLocationCandidates}" SelectedItem="{Binding SelectedSaveLocationCandidate}" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
    <ListBox.ItemContainerStyle>
        <Style TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource Text}"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True"><Setter Property="Background" Value="{DynamicResource NavActive}"/></Trigger>
                <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="{DynamicResource ButtonHover}"/></Trigger>
            </Style.Triggers>
        </Style>
    </ListBox.ItemContainerStyle>
    <ListBox.ItemTemplate>
        <DataTemplate>
            <Border Padding="10" Background="Transparent" BorderBrush="{DynamicResource Border}" BorderThickness="1" CornerRadius="6">
                <StackPanel>
                    <TextBlock Foreground="{DynamicResource Text}" FontWeight="SemiBold" Text="{Binding Path}" TextTrimming="CharacterEllipsis" ToolTip="{Binding Path}"/>
                    <StackPanel Margin="0,5,0,0" Orientation="Horizontal">
                        <TextBlock Foreground="{DynamicResource Muted}" FontSize="12" Text="可信度："/><TextBlock Foreground="{DynamicResource GameCardAccent}" FontSize="12" Text="{Binding Confidence}"/><TextBlock Foreground="{DynamicResource Muted}" FontSize="12" Text="%"/>
                        <TextBlock Margin="14,0,0,0" Foreground="{DynamicResource Muted}" FontSize="12" Text="来源："/><TextBlock Foreground="{DynamicResource Text}" FontSize="12" Text="{Binding Source}"/>
                        <TextBlock Margin="14,0,0,0" Foreground="{DynamicResource Muted}" FontSize="12" Text="文件："/><TextBlock Foreground="{DynamicResource Text}" FontSize="12" Text="{Binding FileCount}"/>
                    </StackPanel>
                    <TextBlock Margin="0,4,0,0" Foreground="{DynamicResource Muted}" FontSize="12" Text="{Binding Reason}" TextTrimming="CharacterEllipsis" ToolTip="{Binding Reason}"/>
                </StackPanel>
            </Border>
        </DataTemplate>
    </ListBox.ItemTemplate>
</ListBox>
<StackPanel Margin="0,10,0,0" Orientation="Horizontal"><Button Style="{StaticResource ButtonStyle}" Command="{Binding PreviewSaveDirectoryCommand}" Content="查看预览"/><Button Margin="10,0,0,0" Style="{StaticResource Primary}" Command="{Binding ConfirmSaveDirectoryCommand}" Content="确认并使用目录"/><TextBlock Margin="12,0,0,0" VerticalAlignment="Center" Foreground="{DynamicResource Muted}" Text="{Binding SaveDirectoryConfirmationText}"/></StackPanel><TextBlock Margin="0,8,0,0" Foreground="{DynamicResource Muted}" Text="{Binding SaveDirectoryPreviewText}" TextWrapping="Wrap"/>
<TextBlock Margin="0,18,0,7" Foreground="{DynamicResource Muted}" Text="附加存档目录（可选）"/>
<TextBlock Margin="0,0,0,8" Foreground="{DynamicResource Muted}" FontSize="12" Text="适用于存档分散在多个目录的游戏；路径会分别标记，恢复时将回到各自原目录。" TextWrapping="Wrap"/>
<Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="10"/><ColumnDefinition Width="110"/></Grid.ColumnDefinitions><TextBox Style="{StaticResource Input}" Text="{Binding AdditionalSaveRootPath, UpdateSourceTrigger=PropertyChanged}" ToolTip="附加存档目录"/><Button Grid.Column="2" Style="{StaticResource ButtonStyle}" Command="{Binding AddAdditionalSaveRootCommand}" Content="添加目录"/></Grid>
<ListBox Margin="0,10,0,0" MaxHeight="116" Background="{DynamicResource InputBackground}" BorderBrush="{DynamicResource Border}" BorderThickness="1" Foreground="{DynamicResource Text}" ItemsSource="{Binding AdditionalSaveRoots}" SelectedItem="{Binding SelectedAdditionalSaveRoot}"><ListBox.ItemTemplate><DataTemplate><DockPanel Margin="8,5"><Button DockPanel.Dock="Right" Style="{StaticResource ButtonStyle}" Command="{Binding DataContext.RemoveAdditionalSaveRootCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Content="移除"/><TextBlock VerticalAlignment="Center" Foreground="{DynamicResource Text}" Text="{Binding Path}" TextTrimming="CharacterEllipsis" ToolTip="{Binding Path}"/></DockPanel></DataTemplate></ListBox.ItemTemplate></ListBox><TextBlock Margin="0,18,0,7" Foreground="{DynamicResource Muted}" Text="注册表存档（可选，仅 HKCU）"/>
<TextBlock Margin="0,0,0,8" Foreground="{DynamicResource Muted}" FontSize="12" Text="会将明确配置的当前用户注册表键导出为 JSON；恢复前自动保留本机注册表安全备份。" TextWrapping="Wrap"/>
<Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="10"/><ColumnDefinition Width="110"/></Grid.ColumnDefinitions><TextBox Style="{StaticResource Input}" Text="{Binding RegistrySaveKeyPath, UpdateSourceTrigger=PropertyChanged}" ToolTip="例如 HKCU\Software\厂商\游戏"/><Button Grid.Column="2" Style="{StaticResource ButtonStyle}" Command="{Binding AddRegistrySaveRuleCommand}" Content="添加注册表"/></Grid>
<ListBox Margin="0,10,0,0" MaxHeight="116" Background="{DynamicResource InputBackground}" BorderBrush="{DynamicResource Border}" BorderThickness="1" Foreground="{DynamicResource Text}" ItemsSource="{Binding RegistrySaveRules}" SelectedItem="{Binding SelectedRegistrySaveRule}"><ListBox.ItemTemplate><DataTemplate><DockPanel Margin="8,5"><Button DockPanel.Dock="Right" Style="{StaticResource ButtonStyle}" Command="{Binding DataContext.RemoveRegistrySaveRuleCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Content="移除"/><TextBlock VerticalAlignment="Center" Foreground="{DynamicResource Text}" Text="{Binding KeyPath}" TextTrimming="CharacterEllipsis" ToolTip="{Binding KeyPath}"/></DockPanel></DataTemplate></ListBox.ItemTemplate></ListBox>
<StackPanel Margin="0,10,0,0" Orientation="Horizontal"><Button Style="{StaticResource ButtonStyle}" Command="{Binding StartSaveLearningCommand}" Content="启动游戏并学习"/><Button Margin="10,0,0,0" Style="{StaticResource ButtonStyle}" Command="{Binding CompleteSaveLearningCommand}" Content="完成学习"/><Button Margin="10,0,0,0" Style="{StaticResource ButtonStyle}" Command="{Binding CancelSaveLearningCommand}" Content="取消学习"/></StackPanel>
<StackPanel Margin="0,18,0,0" Orientation="Horizontal">
                        <Button Style="{StaticResource ButtonStyle}" Margin="0,0,10,0" Command="{Binding LoadLocalProfileCommand}" Content="加载本机配置"/>
                        <Button Style="{StaticResource ButtonStyle}" Margin="0,0,10,0" Command="{Binding BuildManifestCommand}" Content="构建 Manifest"/>
                        <Button Style="{StaticResource Primary}" Command="{Binding SyncCommand}" Content="立即同步"/>
                    </StackPanel>
                </StackPanel>
            </Border>
            <Border Margin="0,18,0,0" Padding="24" Style="{StaticResource PanelStyle}">
                <StackPanel>
                    <TextBlock Foreground="{DynamicResource Text}" FontSize="18" FontWeight="SemiBold" Text="自动同步"/>
                    <TextBlock Margin="0,8,0,6" Foreground="{DynamicResource Muted}" Text="使用当前游戏已经保存的启动入口和存档目录，无需再次选择。"/>
                    <TextBlock Margin="0,0,0,14" Foreground="{DynamicResource Muted}" FontSize="12" Text="{Binding AutoSyncConfigurationText}" TextWrapping="Wrap"/>
                    <StackPanel Orientation="Horizontal">
                        <Button Command="{Binding StartAutoSnapshotCommand}" Content="启用自动同步">
                            <Button.Style><Style TargetType="Button" BasedOn="{StaticResource Primary}"><Style.Triggers><DataTrigger Binding="{Binding IsAutoSyncEnabled}" Value="True"><Setter Property="Visibility" Value="Collapsed"/></DataTrigger></Style.Triggers></Style></Button.Style>
                        </Button>
                        <Button Command="{Binding StopAutoSnapshotCommand}" Content="取消自动同步">
                            <Button.Style><Style TargetType="Button" BasedOn="{StaticResource ButtonStyle}"><Setter Property="Visibility" Value="Collapsed"/><Style.Triggers><DataTrigger Binding="{Binding IsAutoSyncEnabled}" Value="True"><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers></Style></Button.Style>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>
            <Border Margin="0,18,0,0" Padding="22" Style="{StaticResource PanelStyle}">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBlock Foreground="{DynamicResource Text}" FontSize="18" FontWeight="SemiBold" Text="同步任务"/>
                        <StackPanel Grid.Column="1" HorizontalAlignment="Right" Orientation="Horizontal">
                            <Button Style="{StaticResource ButtonStyle}" Margin="0,0,8,0" Command="{Binding RetrySyncCommand}" Content="重试"/>
                            <Button Style="{StaticResource ButtonStyle}" Command="{Binding CancelSyncCommand}" Content="取消"/>
                        </StackPanel>
                    </Grid>
                    <TextBlock Margin="0,14,0,8" Foreground="{DynamicResource Muted}" Text="{Binding SyncProgressText}"/>
                    <ProgressBar Height="9" Maximum="100" Value="{Binding SyncProgressValue, Mode=OneWay}"/>
                    <TextBlock Margin="0,8,0,0" Foreground="{DynamicResource Muted}" FontSize="12" Text="{Binding SyncSummaryText, Mode=OneWay}" TextWrapping="Wrap"/>
                    <TextBlock Margin="0,8,0,0" Foreground="{DynamicResource Muted}" FontSize="12" Text="自动同步和手动同步共用一个安全队列，避免同一时间提交相互覆盖。"/>
                </StackPanel>
            </Border>
            <Grid Margin="0,18,0,0">
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="16"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                <Border Padding="20" Style="{StaticResource PanelStyle}"><StackPanel><TextBlock Foreground="{DynamicResource Muted}" Text="本次文件数量"/><TextBlock Margin="0,8,0,0" Foreground="{DynamicResource Text}" FontSize="30" FontWeight="SemiBold" Text="{Binding FileCount}"/></StackPanel></Border>
                <Border Grid.Column="2" Padding="20" Style="{StaticResource PanelStyle}"><StackPanel><TextBlock Foreground="{DynamicResource Muted}" Text="逻辑存档大小"/><TextBlock Margin="0,8,0,0" Foreground="{DynamicResource Text}" FontSize="30" FontWeight="SemiBold" Text="{Binding LogicalSizeText}"/></StackPanel></Border>
            </Grid>
            <Border Margin="0,18,0,0" Padding="16" Style="{StaticResource PanelStyle}"><TextBlock Foreground="{DynamicResource Muted}" Text="{Binding StatusText}" TextWrapping="Wrap"/></Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>

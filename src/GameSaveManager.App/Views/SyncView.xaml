<UserControl x:Class="GameSaveManager.App.Views.SyncView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
<ScrollViewer VerticalScrollBarVisibility="Auto"><StackPanel Margin="34,28,34,32"><TextBlock Foreground="{DynamicResource Text}" FontSize="30" FontWeight="Bold" Text="同步中心"/><TextBlock Margin="0,8,0,24" Foreground="{DynamicResource Muted}" Text="配置本地存档目录、构建 Manifest，并创建不可变云端快照。"/>
<Border Padding="24" Style="{StaticResource PanelStyle}"><StackPanel><TextBlock Foreground="{DynamicResource Text}" FontSize="18" FontWeight="SemiBold" Text="手动同步"/><TextBlock Margin="0,18,0,7" Foreground="{DynamicResource Muted}" Text="当前游戏"/><ComboBox Height="40" Padding="10,4" ItemsSource="{Binding Games}" SelectedItem="{Binding SelectedGame}" DisplayMemberPath="Name"/><TextBlock Margin="0,18,0,7" Foreground="{DynamicResource Muted}" Text="存档目录"/><TextBox Style="{StaticResource Input}" Text="{Binding SaveDirectory, UpdateSourceTrigger=PropertyChanged}"/><StackPanel Margin="0,18,0,0" Orientation="Horizontal"><Button Style="{StaticResource ButtonStyle}" Margin="0,0,10,0" Command="{Binding LoadLocalProfileCommand}" Content="加载本机配置"/><Button Style="{StaticResource ButtonStyle}" Margin="0,0,10,0" Command="{Binding BuildManifestCommand}" Content="构建 Manifest"/><Button Style="{StaticResource Primary}" Command="{Binding SyncCommand}" Content="立即同步"/></StackPanel></StackPanel></Border>
<Border Margin="0,18,0,0" Padding="24" Style="{StaticResource PanelStyle}"><StackPanel><TextBlock Foreground="{DynamicResource Text}" FontSize="18" FontWeight="SemiBold" Text="自动同步"/><TextBlock Margin="0,8,0,14" Foreground="{DynamicResource Muted}" Text="FileSystemWatcher 只标记存档变更；游戏进程退出后才进行完整扫描和同步。"/><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="14"/><ColumnDefinition Width="150"/><ColumnDefinition Width="10"/><ColumnDefinition Width="130"/></Grid.ColumnDefinitions><TextBox Style="{StaticResource Input}" Text="{Binding AutoSnapshotProcessName, UpdateSourceTrigger=PropertyChanged}" ToolTip="例如 eldenring.exe"/><Button Grid.Column="2" Style="{StaticResource Primary}" Command="{Binding StartAutoSnapshotCommand}" Content="启用自动同步"/><Button Grid.Column="4" Style="{StaticResource ButtonStyle}" Command="{Binding StopAutoSnapshotCommand}" Content="停止自动同步"/></Grid></StackPanel></Border>
<Grid Margin="0,18,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="16"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><Border Padding="20" Style="{StaticResource PanelStyle}"><StackPanel><TextBlock Foreground="{DynamicResource Muted}" Text="本次文件数量"/><TextBlock Margin="0,8,0,0" Foreground="{DynamicResource Text}" FontSize="30" FontWeight="SemiBold" Text="{Binding FileCount}"/></StackPanel></Border><Border Grid.Column="2" Padding="20" Style="{StaticResource PanelStyle}"><StackPanel><TextBlock Foreground="{DynamicResource Muted}" Text="逻辑存档大小"/><TextBlock Margin="0,8,0,0" Foreground="{DynamicResource Text}" FontSize="30" FontWeight="SemiBold" Text="{Binding LogicalSizeText}"/></StackPanel></Border></Grid>
<Border Margin="0,18,0,0" Padding="16" Style="{StaticResource PanelStyle}"><TextBlock Foreground="{DynamicResource Muted}" Text="{Binding StatusText}" TextWrapping="Wrap"/></Border></StackPanel></ScrollViewer>
</UserControl>
<UserControl x:Class="GameSaveManager.App.Views.SettingsView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
<ScrollViewer VerticalScrollBarVisibility="Auto"><StackPanel Margin="34,28,34,32"><TextBlock Foreground="{DynamicResource Text}" FontSize="30" FontWeight="Bold" Text="设置"/><TextBlock Margin="0,8,0,24" Foreground="{DynamicResource Muted}" Text="调整显示偏好与快照保留策略；账户登录请前往“账户”。"/>
<Border Padding="24" Style="{StaticResource PanelStyle}"><DockPanel><StackPanel DockPanel.Dock="Left"><TextBlock Foreground="{DynamicResource Text}" FontSize="18" FontWeight="SemiBold" Text="外观"/><TextBlock Margin="0,8,0,0" Foreground="{DynamicResource Muted}" Text="选择客户端使用的显示主题。"/></StackPanel><ComboBox DockPanel.Dock="Right" Width="160" SelectedIndex="{Binding ThemeSelectionIndex, Mode=OneWay}" SelectionChanged="ThemeSelection_OnSelectionChanged"><ComboBoxItem Content="深色主题"/><ComboBoxItem Content="浅色主题"/></ComboBox></DockPanel></Border>
<Border Margin="0,18,0,0" Padding="24" Style="{StaticResource PanelStyle}"><DockPanel><StackPanel DockPanel.Dock="Left"><TextBlock Foreground="{DynamicResource Text}" FontSize="18" FontWeight="SemiBold" Text="后台启动"/><TextBlock Margin="0,8,0,0" Foreground="{DynamicResource Muted}" Text="开机后以当前用户身份启动客户端，已启用游戏会恢复监听。"/></StackPanel><ComboBox DockPanel.Dock="Right" Width="160" SelectedIndex="{Binding AutoStartSelectionIndex, Mode=OneWay}" SelectionChanged="AutoStartSelection_OnSelectionChanged"><ComboBoxItem Content="不开机启动"/><ComboBoxItem Content="开机启动"/></ComboBox></DockPanel></Border>
<Border Margin="0,18,0,0" Padding="24" Style="{StaticResource PanelStyle}"><StackPanel><TextBlock Foreground="{DynamicResource Text}" FontSize="18" FontWeight="SemiBold" Text="快照保留策略"/><TextBlock Margin="0,8,0,0" Foreground="{DynamicResource Muted}" Text="当前同步 HEAD 永远保留；策略只清理历史快照。"/><Grid Margin="0,18,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="16"/><ColumnDefinition Width="120"/><ColumnDefinition Width="12"/><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><CheckBox VerticalAlignment="Center" Foreground="{DynamicResource Text}" IsChecked="{Binding RetentionEnabled}" Content="启用自动清理"/><TextBox Grid.Column="2" Style="{StaticResource Input}" Text="{Binding RetentionCountText, UpdateSourceTrigger=PropertyChanged}" ToolTip="最多保留快照数"/><TextBox Grid.Column="4" Style="{StaticResource Input}" Text="{Binding RetentionDaysText, UpdateSourceTrigger=PropertyChanged}" ToolTip="保留天数，0 表示不按时间"/><StackPanel Grid.Column="5" HorizontalAlignment="Right" Orientation="Horizontal"><Button Style="{StaticResource ButtonStyle}" Margin="0,0,8,0" Command="{Binding ReloadRetentionCommand}" Content="加载策略"/><Button Style="{StaticResource ButtonStyle}" Margin="0,0,8,0" Command="{Binding CleanupRetentionCommand}" Content="立即清理"/><Button Style="{StaticResource Primary}" Command="{Binding SaveRetentionCommand}" Content="保存策略"/></StackPanel></Grid></StackPanel></Border>
<Border Margin="0,18,0,0" Padding="16" Style="{StaticResource PanelStyle}"><TextBlock Foreground="{DynamicResource Muted}" Text="{Binding StatusText}" TextWrapping="Wrap"/></Border></StackPanel></ScrollViewer>
</UserControl>
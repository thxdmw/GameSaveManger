<UserControl x:Class="GameSaveManager.App.Views.SettingsView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
<ScrollViewer VerticalScrollBarVisibility="Auto"><StackPanel Margin="34,28,34,32"><TextBlock Foreground="White" FontSize="30" FontWeight="Bold" Text="设置"/><TextBlock Margin="0,8,0,24" Foreground="{StaticResource Muted}" Text="连接你的 GameSave 服务端，并设置快照保留策略。"/>
<Border Padding="24" Style="{StaticResource PanelStyle}"><StackPanel><TextBlock Foreground="White" FontSize="18" FontWeight="SemiBold" Text="账号与服务端"/><TextBlock Margin="0,18,0,7" Foreground="{StaticResource Muted}" Text="服务端地址"/><TextBox Style="{StaticResource Input}" Text="{Binding ServerAddress, UpdateSourceTrigger=PropertyChanged}"/><Grid Margin="0,14,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="12"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBox Style="{StaticResource Input}" Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" ToolTip="用户名"/><PasswordBox x:Name="PasswordInput" Grid.Column="2" Height="40" Padding="12,0" VerticalContentAlignment="Center" Foreground="White" Background="#0A121D" BorderBrush="#2A3B53" PasswordChanged="PasswordBox_OnPasswordChanged"/></Grid><StackPanel Margin="0,16,0,0" Orientation="Horizontal" HorizontalAlignment="Right"><Button Style="{StaticResource ButtonStyle}" Margin="0,0,10,0" Command="{Binding RegisterCommand}" Content="注册"/><Button Style="{StaticResource Primary}" Command="{Binding LoginCommand}" Content="登录"/></StackPanel><TextBlock Margin="0,10,0,0" Foreground="#98A9C0" FontSize="12" Text="设备 Token 仅保存到 Windows Credential Manager；远程服务端必须使用 HTTPS。"/></StackPanel></Border>
<Border Margin="0,18,0,0" Padding="24" Style="{StaticResource PanelStyle}"><StackPanel><TextBlock Foreground="White" FontSize="18" FontWeight="SemiBold" Text="快照保留策略"/><TextBlock Margin="0,8,0,0" Foreground="{StaticResource Muted}" Text="当前同步 HEAD 永远保留；策略只清理历史快照。"/><Grid Margin="0,18,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="16"/><ColumnDefinition Width="120"/><ColumnDefinition Width="12"/><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><CheckBox VerticalAlignment="Center" Foreground="White" IsChecked="{Binding RetentionEnabled}" Content="启用自动清理"/><TextBox Grid.Column="2" Style="{StaticResource Input}" Text="{Binding RetentionCountText, UpdateSourceTrigger=PropertyChanged}" ToolTip="最多保留快照数"/><TextBox Grid.Column="4" Style="{StaticResource Input}" Text="{Binding RetentionDaysText, UpdateSourceTrigger=PropertyChanged}" ToolTip="保留天数，0 表示不按时间"/><StackPanel Grid.Column="5" HorizontalAlignment="Right" Orientation="Horizontal"><Button Style="{StaticResource ButtonStyle}" Margin="0,0,8,0" Command="{Binding ReloadRetentionCommand}" Content="加载策略"/><Button Style="{StaticResource ButtonStyle}" Margin="0,0,8,0" Command="{Binding CleanupRetentionCommand}" Content="立即清理"/><Button Style="{StaticResource Primary}" Command="{Binding SaveRetentionCommand}" Content="保存策略"/></StackPanel></Grid></StackPanel></Border>
<Border Margin="0,18,0,0" Padding="16" Style="{StaticResource PanelStyle}"><TextBlock Foreground="#AABBD0" Text="{Binding StatusText}" TextWrapping="Wrap"/></Border></StackPanel></ScrollViewer>
</UserControl>
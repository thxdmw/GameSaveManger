<UserControl x:Class="GameSaveManager.App.Views.SettingsView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
<ScrollViewer VerticalScrollBarVisibility="Auto"><StackPanel Margin="34,28,34,32"><TextBlock Foreground="{DynamicResource Text}" FontSize="30" FontWeight="Bold" Text="设置"/><TextBlock Margin="0,8,0,24" Foreground="{DynamicResource Muted}" Text="连接你的 GameSave 服务端，并设置快照保留策略。"/>
<Border Padding="24" Style="{StaticResource PanelStyle}"><StackPanel><DockPanel><TextBlock DockPanel.Dock="Left" Foreground="{DynamicResource Text}" FontSize="18" FontWeight="SemiBold" Text="账号与服务端"/><Button DockPanel.Dock="Right" Style="{StaticResource ButtonStyle}" Command="{Binding ToggleThemeCommand}" Content="{Binding ThemeToggleText}"/></DockPanel><TextBlock Margin="0,18,0,7" Foreground="{DynamicResource Muted}" Text="服务端地址"/><TextBox Style="{StaticResource Input}" Text="{Binding ServerAddress, UpdateSourceTrigger=PropertyChanged}"/><Grid Margin="0,14,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="12"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><StackPanel><TextBlock Margin="0,0,0,7" Foreground="{DynamicResource Muted}" Text="账号（注册时创建，登录时使用）"/><TextBox Style="{StaticResource Input}" Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" ToolTip="GameSave 账号"/></StackPanel><StackPanel Grid.Column="2"><TextBlock Margin="0,0,0,7" Foreground="{DynamicResource Muted}" Text="密码（至少 8 位）"/><PasswordBox x:Name="PasswordInput" Height="40" Padding="12,0" VerticalContentAlignment="Center" Foreground="{DynamicResource Text}" ToolTip="GameSave 密码" PasswordChanged="PasswordBox_OnPasswordChanged"/></StackPanel></Grid><StackPanel Margin="0,16,0,0" Orientation="Horizontal" HorizontalAlignment="Right"><Button Style="{StaticResource ButtonStyle}" Margin="0,0,10,0" Command="{Binding RegisterCommand}" Content="注册"/><Button Style="{StaticResource Primary}" Command="{Binding LoginCommand}" Content="登录"/></StackPanel><TextBlock Margin="0,10,0,0" Foreground="{DynamicResource Muted}" FontSize="12" Text="设备标识与设备名称由客户端自动生成；设备 Token 仅保存到 Windows Credential Manager；远程服务端必须使用 HTTPS。"/></StackPanel></Border>
<Border Margin="0,18,0,0" Padding="24" Style="{StaticResource PanelStyle}"><StackPanel><TextBlock Foreground="{DynamicResource Text}" FontSize="18" FontWeight="SemiBold" Text="快照保留策略"/><TextBlock Margin="0,8,0,0" Foreground="{DynamicResource Muted}" Text="当前同步 HEAD 永远保留；策略只清理历史快照。"/><Grid Margin="0,18,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="16"/><ColumnDefinition Width="120"/><ColumnDefinition Width="12"/><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><CheckBox VerticalAlignment="Center" Foreground="{DynamicResource Text}" IsChecked="{Binding RetentionEnabled}" Content="启用自动清理"/><TextBox Grid.Column="2" Style="{StaticResource Input}" Text="{Binding RetentionCountText, UpdateSourceTrigger=PropertyChanged}" ToolTip="最多保留快照数"/><TextBox Grid.Column="4" Style="{StaticResource Input}" Text="{Binding RetentionDaysText, UpdateSourceTrigger=PropertyChanged}" ToolTip="保留天数，0 表示不按时间"/><StackPanel Grid.Column="5" HorizontalAlignment="Right" Orientation="Horizontal"><Button Style="{StaticResource ButtonStyle}" Margin="0,0,8,0" Command="{Binding ReloadRetentionCommand}" Content="加载策略"/><Button Style="{StaticResource ButtonStyle}" Margin="0,0,8,0" Command="{Binding CleanupRetentionCommand}" Content="立即清理"/><Button Style="{StaticResource Primary}" Command="{Binding SaveRetentionCommand}" Content="保存策略"/></StackPanel></Grid></StackPanel></Border>
<Border Margin="0,18,0,0" Padding="16" Style="{StaticResource PanelStyle}"><TextBlock Foreground="{DynamicResource Muted}" Text="{Binding StatusText}" TextWrapping="Wrap"/></Border></StackPanel></ScrollViewer>
</UserControl>
<UserControl x:Class="GameSaveManager.App.Views.SettingsView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
<ScrollViewer VerticalScrollBarVisibility="Auto"><StackPanel Margin="34,28,34,32"><TextBlock Foreground="{DynamicResource Text}" FontSize="30" FontWeight="Bold" Text="设置"/><TextBlock Margin="0,8,0,24" Foreground="{DynamicResource Muted}" Text="调整显示偏好与快照保留策略；账户登录请前往“账户”。"/>
<Border Padding="24" Style="{StaticResource PanelStyle}"><DockPanel LastChildFill="False"><StackPanel DockPanel.Dock="Left"><TextBlock Foreground="{DynamicResource Text}" FontSize="18" FontWeight="SemiBold" Text="外观"/><TextBlock Margin="0,8,0,0" Foreground="{DynamicResource Muted}" Text="选择客户端使用的显示主题。"/></StackPanel><ComboBox DockPanel.Dock="Right" Width="160" SelectedIndex="{Binding ThemeSelectionIndex, Mode=OneWay}" SelectionChanged="ThemeSelection_OnSelectionChanged"><ComboBoxItem Content="深色主题"/><ComboBoxItem Content="浅色主题"/></ComboBox></DockPanel></Border>
<Border Margin="0,18,0,0" Padding="24" Style="{StaticResource PanelStyle}"><DockPanel LastChildFill="False"><StackPanel DockPanel.Dock="Left"><TextBlock Foreground="{DynamicResource Text}" FontSize="18" FontWeight="SemiBold" Text="后台启动"/><TextBlock Margin="0,8,0,0" Foreground="{DynamicResource Muted}" Text="开机后以当前用户身份启动客户端，已启用游戏会恢复监听。"/></StackPanel><ComboBox DockPanel.Dock="Right" Width="160" SelectedIndex="{Binding AutoStartSelectionIndex, Mode=OneWay}" SelectionChanged="AutoStartSelection_OnSelectionChanged"><ComboBoxItem Content="不开机启动"/><ComboBoxItem Content="开机启动"/></ComboBox></DockPanel></Border>
<Border Margin="0,18,0,0" Padding="24" Style="{StaticResource PanelStyle}"><DockPanel LastChildFill="False"><StackPanel DockPanel.Dock="Left"><TextBlock Foreground="{DynamicResource Text}" FontSize="18" FontWeight="SemiBold" Text="存档识别规则"/><TextBlock Margin="0,8,0,0" Foreground="{DynamicResource Muted}" Text="{Binding ManifestUpdateStatusText}" TextWrapping="Wrap"/></StackPanel><Button DockPanel.Dock="Right" Style="{StaticResource ButtonStyle}" Command="{Binding UpdateManifestCommand}" Content="检查更新"/></DockPanel></Border>
<Border Margin="0,18,0,0" Padding="24" Style="{StaticResource PanelStyle}"><DockPanel LastChildFill="False"><StackPanel DockPanel.Dock="Left" Margin="0,0,24,0"><TextBlock Foreground="{DynamicResource Text}" FontSize="18" FontWeight="SemiBold" Text="本地缓存与恢复空间"/><TextBlock Margin="0,8,0,0" Foreground="{DynamicResource Muted}" Text="{Binding LocalStorageUsageText}" TextWrapping="Wrap"/></StackPanel><Button DockPanel.Dock="Right" Style="{StaticResource ButtonStyle}" Command="{Binding CleanupLocalStorageCommand}" Content="安全清理缓存"/></DockPanel></Border>
<Border Margin="0,18,0,0" Padding="24" Style="{StaticResource PanelStyle}"><StackPanel><TextBlock Foreground="{DynamicResource Text}" FontSize="18" FontWeight="SemiBold" Text="快照保留策略"/><TextBlock Margin="0,8,0,0" Foreground="{DynamicResource Muted}" Text="当前同步 HEAD 永远保留；策略只清理历史快照。"/><TextBlock Margin="0,5,0,0" Foreground="{DynamicResource Warning}" Text="{Binding SelectedGame.Name, StringFormat=当前策略目标：{0}, TargetNullValue=当前未选择游戏}"/><Grid Margin="0,18,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="16"/><ColumnDefinition Width="120"/><ColumnDefinition Width="12"/><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><CheckBox VerticalAlignment="Center" Foreground="{DynamicResource Text}" IsChecked="{Binding RetentionEnabled}" Content="启用自动清理"/><TextBox Grid.Column="2" Style="{StaticResource Input}" Text="{Binding RetentionCountText, UpdateSourceTrigger=PropertyChanged}" ToolTip="最多保留快照数"/><TextBox Grid.Column="4" Style="{StaticResource Input}" Text="{Binding RetentionDaysText, UpdateSourceTrigger=PropertyChanged}" ToolTip="保留天数，0 表示不按时间"/><StackPanel Grid.Column="5" HorizontalAlignment="Right" Orientation="Horizontal"><Button Style="{StaticResource ButtonStyle}" Margin="0,0,8,0" Command="{Binding ReloadRetentionCommand}" Content="加载策略"/><Button Style="{StaticResource ButtonStyle}" Margin="0,0,8,0" Command="{Binding CleanupRetentionCommand}" Content="立即清理"/><Button Style="{StaticResource Primary}" Command="{Binding SaveRetentionCommand}" Content="保存策略"/></StackPanel></Grid></StackPanel></Border>
<Border Margin="0,18,0,0" Padding="24" Style="{StaticResource PanelStyle}">
    <Grid>
        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
        <StackPanel Margin="0,0,24,0">
            <TextBlock Foreground="{DynamicResource Text}" FontSize="18" FontWeight="SemiBold" Text="客户端版本与更新"/>
            <StackPanel Margin="0,10,0,0" Orientation="Horizontal"><TextBlock Foreground="{DynamicResource Muted}" Text="当前版本："/><TextBlock Foreground="{DynamicResource Text}" FontWeight="SemiBold" Text="{Binding ClientVersionText, Mode=OneWay}"/><TextBlock Margin="28,0,0,0" Foreground="{DynamicResource Muted}" Text="发布通道："/><TextBlock Foreground="{DynamicResource Text}" FontWeight="SemiBold" Text="{Binding ClientReleaseChannelText, Mode=OneWay}"/></StackPanel>
            <TextBlock Margin="0,8,0,0" Foreground="{DynamicResource Muted}" Text="{Binding UpdateStatusText, Mode=OneWay}" TextWrapping="Wrap"/>
            <ProgressBar Margin="0,12,0,0" Value="{Binding UpdateDownloadProgress, Mode=OneWay}"><ProgressBar.Style><Style TargetType="ProgressBar" BasedOn="{StaticResource SyncProgressBar}"><Setter Property="Visibility" Value="Collapsed"/><Style.Triggers><DataTrigger Binding="{Binding IsUpdateDownloading}" Value="True"><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers></Style></ProgressBar.Style></ProgressBar>
        </StackPanel>
        <StackPanel Grid.Column="1" HorizontalAlignment="Right">
            <ComboBox Width="190" SelectedIndex="{Binding UpdateCheckOnStartupSelectionIndex, Mode=OneWay}" SelectionChanged="UpdateCheckSelection_OnSelectionChanged"><ComboBoxItem Content="不在启动时检查"/><ComboBoxItem Content="启动后后台检查"/></ComboBox>
            <WrapPanel Margin="0,10,0,0" HorizontalAlignment="Right">
                <Button Margin="0,0,8,0" Style="{StaticResource ButtonStyle}" Command="{Binding CheckForUpdateCommand}" Content="检查更新"/>
                <Button Margin="0,0,8,0" Command="{Binding DownloadUpdateCommand}" Content="下载更新"><Button.Style><Style TargetType="Button" BasedOn="{StaticResource Primary}"><Setter Property="Visibility" Value="Collapsed"/><Style.Triggers><MultiDataTrigger><MultiDataTrigger.Conditions><Condition Binding="{Binding HasAvailableUpdate}" Value="True"/><Condition Binding="{Binding HasPreparedUpdate}" Value="False"/><Condition Binding="{Binding IsUpdateDownloading}" Value="False"/></MultiDataTrigger.Conditions><Setter Property="Visibility" Value="Visible"/></MultiDataTrigger></Style.Triggers></Style></Button.Style></Button>
                <Button Margin="0,0,8,0" Command="{Binding CancelUpdateDownloadCommand}" Content="取消下载"><Button.Style><Style TargetType="Button" BasedOn="{StaticResource ButtonStyle}"><Setter Property="Visibility" Value="Collapsed"/><Style.Triggers><DataTrigger Binding="{Binding IsUpdateDownloading}" Value="True"><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers></Style></Button.Style></Button>
                <Button Command="{Binding InstallUpdateCommand}" Content="退出并安装"><Button.Style><Style TargetType="Button" BasedOn="{StaticResource Primary}"><Setter Property="Visibility" Value="Collapsed"/><Style.Triggers><DataTrigger Binding="{Binding HasPreparedUpdate}" Value="True"><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers></Style></Button.Style></Button>
            </WrapPanel>
        </StackPanel>
    </Grid>
</Border>
<Border Margin="0,18,0,0" Padding="24" Style="{StaticResource PanelStyle}"><DockPanel LastChildFill="False"><StackPanel DockPanel.Dock="Left"><TextBlock Foreground="{DynamicResource Text}" FontSize="18" FontWeight="SemiBold" Text="第三方数据与许可证"/><TextBlock Margin="0,8,0,0" Foreground="{DynamicResource Muted}" Text="Ludusavi Manifest 离线规则数据。"/></StackPanel><Button DockPanel.Dock="Right" Style="{StaticResource ButtonStyle}" Click="ShowThirdPartyNotice_OnClick" Content="查看许可证"/></DockPanel></Border>
<Border Margin="0,18,0,0" Padding="16" Style="{StaticResource PanelStyle}"><TextBlock Foreground="{DynamicResource Muted}" Text="{Binding StatusText}" TextWrapping="Wrap"/></Border></StackPanel></ScrollViewer>
</UserControl>

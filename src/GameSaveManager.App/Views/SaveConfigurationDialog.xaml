<Window x:Class="GameSaveManager.App.Views.SaveConfigurationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="修改存档配置" Width="820" Height="720" MinWidth="700" MinHeight="600"
        WindowStartupLocation="CenterOwner" Background="{DynamicResource AppBackground}">
    <Grid Margin="26">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel>
            <TextBlock Foreground="{DynamicResource Text}" FontSize="26" FontWeight="Bold" Text="存档配置"/>
            <TextBlock Margin="0,7,0,0" Foreground="{DynamicResource Muted}"
                       Text="预览并确认目录后才会保存；超过 5000 个文件时禁止继续。"/>
        </StackPanel>
        <ScrollViewer Grid.Row="1" Margin="0,20,0,18" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Border Padding="20" Style="{StaticResource PanelStyle}">
                    <StackPanel>
                        <TextBlock Foreground="{DynamicResource Text}" FontSize="18" FontWeight="SemiBold" Text="主存档目录"/>
                        <Grid Margin="0,14,0,0">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="10"/><ColumnDefinition Width="110"/></Grid.ColumnDefinitions>
                            <TextBox Style="{StaticResource Input}" Text="{Binding SaveDirectory, UpdateSourceTrigger=PropertyChanged}"/>
                            <Button Grid.Column="2" Style="{StaticResource ButtonStyle}" Click="ChooseDirectory_OnClick" Content="选择目录"/>
                        </Grid>
                        <StackPanel Margin="0,10,0,0" Orientation="Horizontal">
                            <Button Style="{StaticResource ButtonStyle}" Command="{Binding SuggestSaveDirectoriesCommand}" Content="自动检测"/>
                            <Button Margin="10,0,0,0" Style="{StaticResource ButtonStyle}" Command="{Binding PreviewSaveDirectoryCommand}" Content="预览"/>
                            <Button Margin="10,0,0,0" Style="{StaticResource Primary}" Command="{Binding ConfirmSaveDirectoryCommand}" Content="确认并保存"/>
                        </StackPanel>
                        <TextBlock Margin="0,10,0,0" Foreground="{DynamicResource Muted}" Text="{Binding SaveDirectoryPreviewText}" TextWrapping="Wrap"/>
                        <TextBlock Margin="0,6,0,0" Foreground="{DynamicResource Muted}" Text="{Binding SaveDirectoryConfirmationText}"/>
                        <ListBox Margin="0,12,0,0" MaxHeight="180" Style="{StaticResource ThemedListBox}"
                                 ItemContainerStyle="{StaticResource ThemedListBoxItem}" ItemsSource="{Binding SaveLocationCandidates}"
                                 SelectedItem="{Binding SelectedSaveLocationCandidate}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="8">
                                        <TextBlock Foreground="{DynamicResource Text}" Text="{Binding Path}" TextTrimming="CharacterEllipsis" ToolTip="{Binding Path}"/>
                                        <TextBlock Foreground="{DynamicResource Muted}" FontSize="12"
                                                   Text="{Binding Reason}" TextTrimming="CharacterEllipsis" ToolTip="{Binding Reason}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Border>
                <Border Margin="0,16,0,0" Padding="20" Style="{StaticResource PanelStyle}">
                    <StackPanel>
                        <TextBlock Foreground="{DynamicResource Text}" FontSize="18" FontWeight="SemiBold" Text="附加目录"/>
                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="10"/><ColumnDefinition Width="90"/></Grid.ColumnDefinitions>
                            <TextBox Style="{StaticResource Input}" Text="{Binding AdditionalSaveRootPath, UpdateSourceTrigger=PropertyChanged}"/>
                            <Button Grid.Column="2" Style="{StaticResource ButtonStyle}" Command="{Binding AddAdditionalSaveRootCommand}" Content="添加"/>
                        </Grid>
                        <ItemsControl Margin="0,8,0,0" ItemsSource="{Binding AdditionalSaveRoots}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate><TextBlock Margin="4" Foreground="{DynamicResource Text}" Text="{Binding Path}" TextTrimming="CharacterEllipsis" ToolTip="{Binding Path}"/></DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
                <Border Margin="0,16,0,0" Padding="20" Style="{StaticResource PanelStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Foreground="{DynamicResource Text}" FontSize="18" FontWeight="SemiBold" Text="退出后自动备份"/>
                            <TextBlock Margin="0,7,18,0" Foreground="{DynamicResource Muted}"
                                       Text="{Binding AutoSyncConfigurationText}" TextWrapping="Wrap"/>
                        </StackPanel>
                        <Button Grid.Column="1" Command="{Binding StartAutoSnapshotCommand}" Content="开启">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource Primary}">
                                    <Style.Triggers><DataTrigger Binding="{Binding IsAutoSyncEnabled}" Value="True"><Setter Property="Visibility" Value="Collapsed"/></DataTrigger></Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Grid.Column="1" Command="{Binding StopAutoSnapshotCommand}" Content="关闭">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource ButtonStyle}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers><DataTrigger Binding="{Binding IsAutoSyncEnabled}" Value="True"><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>
        <Button Grid.Row="2" HorizontalAlignment="Right" Width="100" Style="{StaticResource ButtonStyle}"
                IsCancel="True" Content="完成"/>
    </Grid>
</Window>

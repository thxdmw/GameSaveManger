<UserControl x:Class="GameSaveManager.App.Views.LibraryView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
<ScrollViewer VerticalScrollBarVisibility="Auto"><StackPanel Margin="34,28,34,32"><TextBlock Foreground="{DynamicResource Text}" FontSize="30" FontWeight="Bold" Text="游戏库"/><TextBlock Margin="0,8,0,24" Foreground="{DynamicResource Muted}" Text="添加和管理需要保护的游戏。右键游戏卡片可删除云端游戏与其全部云端存档。"/>
<Border Padding="24" Style="{StaticResource PanelStyle}"><StackPanel><TextBlock Foreground="{DynamicResource Text}" FontSize="18" FontWeight="SemiBold" Text="添加云端游戏"/><Grid Margin="0,16,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="14"/><ColumnDefinition Width="150"/></Grid.ColumnDefinitions><TextBox Style="{StaticResource Input}" Text="{Binding NewGameName, UpdateSourceTrigger=PropertyChanged}" ToolTip="游戏名称，同一账号下不可重复"/><Button Grid.Column="2" Style="{StaticResource Primary}" Command="{Binding CreateGameCommand}" Content="创建游戏"/></Grid><TextBlock Margin="0,8,0,0" Foreground="{DynamicResource Muted}" FontSize="12" Text="同一账号下游戏名称不能重复；客户端和服务端都会校验。"/><TextBlock Margin="0,20,0,8" Foreground="{DynamicResource Muted}" Text="发现本机安装的游戏"/><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="14"/><ColumnDefinition Width="150"/></Grid.ColumnDefinitions><ComboBox Height="40" Padding="10,4" ItemsSource="{Binding DiscoveredGames}" SelectedItem="{Binding SelectedDiscoveredGame}" DisplayMemberPath="Name"/><Button Grid.Column="2" Style="{StaticResource ButtonStyle}" Command="{Binding DiscoverGamesCommand}" Content="扫描本机游戏"/></Grid></StackPanel></Border>
<TextBlock Margin="0,26,0,14" Foreground="{DynamicResource Text}" FontSize="20" FontWeight="SemiBold" Text="已添加的游戏"/>
<ItemsControl MinHeight="230" ItemsSource="{Binding FilteredGames}"><ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel><ItemsControl.ItemTemplate><DataTemplate><Button Width="205" Height="210" Margin="0,0,16,16" Style="{StaticResource GameCardButton}" Command="{Binding DataContext.SelectGameCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}"><Button.ContextMenu><ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}"><MenuItem Header="删除游戏和云端存档" Click="DeleteGameMenuItem_OnClick"/></ContextMenu></Button.ContextMenu><Border Style="{StaticResource PanelStyle}"><Grid><Grid.RowDefinitions><RowDefinition Height="122"/><RowDefinition Height="*"/></Grid.RowDefinitions><Border CornerRadius="13,13,0,0"><Border.Background><LinearGradientBrush StartPoint="0,0" EndPoint="1,1"><GradientStop Color="#1A3C60"/><GradientStop Color="#172338" Offset=".6"/><GradientStop Color="#46354B" Offset="1"/></LinearGradientBrush></Border.Background><TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#6CACFF" FontSize="20" FontWeight="Bold" Text="{Binding Name}" TextTrimming="CharacterEllipsis"/></Border><StackPanel Grid.Row="1" Margin="13,11"><TextBlock Foreground="{DynamicResource Text}" FontWeight="SemiBold" Text="{Binding Name}" TextTrimming="CharacterEllipsis"/><TextBlock Margin="0,6,0,0" Foreground="{DynamicResource Muted}" FontSize="12" Text="{Binding Provider}"/><TextBlock Margin="0,8,0,0" Foreground="{DynamicResource Muted}" FontSize="12" Text="右键可删除"/></StackPanel></Grid></Border></Button></DataTemplate></ItemsControl.ItemTemplate></ItemsControl>
<Border Padding="16" Style="{StaticResource PanelStyle}"><TextBlock Foreground="{DynamicResource Muted}" Text="{Binding StatusText}" TextWrapping="Wrap"/></Border></StackPanel></ScrollViewer>
</UserControl>
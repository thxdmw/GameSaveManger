<UserControl x:Class="GameSaveManager.App.Views.LibraryView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
<ScrollViewer VerticalScrollBarVisibility="Auto"><StackPanel Margin="34,28,34,32"><TextBlock Foreground="White" FontSize="30" FontWeight="Bold" Text="游戏库"/><TextBlock Margin="0,8,0,24" Foreground="{StaticResource Muted}" Text="扫描、添加并选择需要保护的游戏。"/>
<Border Padding="24" Style="{StaticResource PanelStyle}"><StackPanel><TextBlock Foreground="White" FontSize="18" FontWeight="SemiBold" Text="添加云端游戏"/><Grid Margin="0,16,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="14"/><ColumnDefinition Width="150"/></Grid.ColumnDefinitions><TextBox Style="{StaticResource Input}" Text="{Binding NewGameName, UpdateSourceTrigger=PropertyChanged}" ToolTip="游戏名称"/><Button Grid.Column="2" Style="{StaticResource Primary}" Command="{Binding CreateGameCommand}" Content="创建游戏"/></Grid><TextBlock Margin="0,20,0,8" Foreground="{StaticResource Muted}" Text="发现本机安装的游戏"/><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="14"/><ColumnDefinition Width="150"/></Grid.ColumnDefinitions><ComboBox Height="40" Padding="10,4" ItemsSource="{Binding DiscoveredGames}" SelectedItem="{Binding SelectedDiscoveredGame}" DisplayMemberPath="Name"/><Button Grid.Column="2" Style="{StaticResource ButtonStyle}" Command="{Binding DiscoverGamesCommand}" Content="扫描本机游戏"/></Grid><TextBlock Margin="0,10,0,0" Foreground="#98A9C0" FontSize="12" Text="已支持 Steam、Epic 和 GOG 安装信息扫描；存档路径仍应由你确认。"/></StackPanel></Border>
<TextBlock Margin="0,26,0,14" Foreground="White" FontSize="20" FontWeight="SemiBold" Text="已添加的游戏"/>
<ItemsControl ItemsSource="{Binding FilteredGames}"><ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel><ItemsControl.ItemTemplate><DataTemplate><Button Width="235" Height="130" Margin="0,0,16,16" Background="Transparent" BorderThickness="0" Command="{Binding DataContext.SelectGameCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}"><Border Padding="18" Style="{StaticResource PanelStyle}"><StackPanel><TextBlock Foreground="White" FontSize="18" FontWeight="SemiBold" Text="{Binding Name}" TextTrimming="CharacterEllipsis"/><TextBlock Margin="0,9,0,0" Foreground="#9BAEC7" Text="{Binding Provider}"/><TextBlock Margin="0,18,0,0" Foreground="#5BD9A3" Text="● 点击配置同步"/></StackPanel></Border></Button></DataTemplate></ItemsControl.ItemTemplate></ItemsControl>
<Border Padding="16" Style="{StaticResource PanelStyle}"><TextBlock Foreground="#AABBD0" Text="{Binding StatusText}" TextWrapping="Wrap"/></Border></StackPanel></ScrollViewer>
</UserControl>
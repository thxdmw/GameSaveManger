<UserControl x:Class="GameSaveManager.App.Views.LibraryView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:local="clr-namespace:GameSaveManager.App.Views"><UserControl.Resources><local:GameRuntimeStatusConverter x:Key="GameRuntimeStatusConverter"/><local:GameProtectionStatusConverter x:Key="GameProtectionStatusConverter"/></UserControl.Resources>
<ScrollViewer VerticalScrollBarVisibility="Auto"><StackPanel Margin="34,28,34,32"><TextBlock Foreground="{DynamicResource Text}" FontSize="30" FontWeight="Bold" Text="游戏库"/><TextBlock Margin="0,8,0,24" Foreground="{DynamicResource Muted}" Text="添加和管理需要保护的游戏。右键游戏卡片可删除云端游戏与其全部云端存档。"/>
<Border Padding="24" Style="{StaticResource PanelStyle}"><StackPanel><TextBlock Foreground="{DynamicResource Text}" FontSize="18" FontWeight="SemiBold" Text="添加游戏"/><TextBlock Margin="0,8,0,16" Foreground="{DynamicResource Muted}" Text="使用统一向导导入平台游戏、选择本地启动入口，或手动创建游戏。"/><Button Width="140" Height="40" HorizontalAlignment="Left" Style="{StaticResource Primary}" Click="OpenAddGameWizardButton_OnClick" Content="＋ 添加游戏"/></StackPanel></Border>
<TextBlock Margin="0,26,0,14" Foreground="{DynamicResource Text}" FontSize="20" FontWeight="SemiBold" Text="已添加的游戏"/>
<ItemsControl MinHeight="230" ItemsSource="{Binding FilteredGames}">
  <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
  <ItemsControl.ItemTemplate><DataTemplate>
    <Grid Width="205" Height="210" Margin="0,0,16,16">
      <Grid.ContextMenu><ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}"><MenuItem Header="删除游戏和云端存档" Click="DeleteGameMenuItem_OnClick"/></ContextMenu></Grid.ContextMenu>
      <Border Style="{StaticResource PanelStyle}"><Grid><Grid.RowDefinitions><RowDefinition Height="122"/><RowDefinition Height="*"/></Grid.RowDefinitions><Border CornerRadius="13,13,0,0"><Border.Background><LinearGradientBrush StartPoint="0,0" EndPoint="1,1"><GradientStop Color="#1A3C60"/><GradientStop Color="#172338" Offset=".6"/><GradientStop Color="#46354B" Offset="1"/></LinearGradientBrush></Border.Background><TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#6CACFF" FontSize="20" FontWeight="Bold" Text="{Binding Name}" TextTrimming="CharacterEllipsis"/></Border><StackPanel Grid.Row="1" Margin="13,11"><TextBlock Foreground="{DynamicResource Text}" FontWeight="SemiBold" Text="{Binding Name}" TextTrimming="CharacterEllipsis"/><TextBlock Margin="0,6,0,0" Foreground="{DynamicResource Muted}" FontSize="12" Text="{Binding Provider}"/><TextBlock Margin="0,8,0,0" Foreground="{DynamicResource Muted}" FontSize="12"><TextBlock.Text><MultiBinding Converter="{StaticResource GameRuntimeStatusConverter}"><Binding/><Binding Path="DataContext" RelativeSource="{RelativeSource AncestorType=UserControl}"/><Binding Path="DataContext.RuntimeStatusVersion" RelativeSource="{RelativeSource AncestorType=UserControl}"/></MultiBinding></TextBlock.Text></TextBlock><TextBlock Margin="0,5,0,0" Foreground="{DynamicResource Muted}" FontSize="12"><TextBlock.Text><MultiBinding Converter="{StaticResource GameProtectionStatusConverter}"><Binding/><Binding Path="DataContext" RelativeSource="{RelativeSource AncestorType=UserControl}"/><Binding Path="DataContext.RuntimeStatusVersion" RelativeSource="{RelativeSource AncestorType=UserControl}"/></MultiBinding></TextBlock.Text></TextBlock></StackPanel></Grid></Border>
      <Button Width="62" Height="28" Margin="0,0,12,10" HorizontalAlignment="Right" VerticalAlignment="Bottom" Style="{StaticResource Primary}" Command="{Binding DataContext.LaunchGameCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Content="启动"/>
    </Grid>
  </DataTemplate></ItemsControl.ItemTemplate>
</ItemsControl><Border Padding="16" Style="{StaticResource PanelStyle}"><TextBlock Foreground="{DynamicResource Muted}" Text="{Binding StatusText}" TextWrapping="Wrap"/></Border></StackPanel></ScrollViewer>
</UserControl>
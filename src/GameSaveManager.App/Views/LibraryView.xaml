<UserControl x:Class="GameSaveManager.App.Views.LibraryView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:local="clr-namespace:GameSaveManager.App.Views">
<UserControl.Resources>
  <local:GameRuntimeStatusConverter x:Key="GameRuntimeStatusConverter"/>
  <local:GameProtectionStatusConverter x:Key="GameProtectionStatusConverter"/>
  <local:GameLaunchDisabledReasonConverter x:Key="GameLaunchDisabledReasonConverter"/>
  <Style x:Key="GameCardContextMenuStyle" TargetType="ContextMenu">
    <Setter Property="MinWidth" Value="132"/><Setter Property="Padding" Value="4"/><Setter Property="Background" Value="{DynamicResource Panel}"/><Setter Property="BorderBrush" Value="{DynamicResource Border}"/><Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="ContextMenu"><Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8"><ItemsPresenter KeyboardNavigation.DirectionalNavigation="Cycle"/></Border></ControlTemplate></Setter.Value></Setter>
  </Style>
  <Style x:Key="GameCardMenuItemStyle" TargetType="MenuItem">
    <Setter Property="Foreground" Value="{DynamicResource Text}"/><Setter Property="Background" Value="Transparent"/><Setter Property="Cursor" Value="Hand"/>
    <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="MenuItem"><Border x:Name="root" Margin="0,1" Padding="12,8" Background="{TemplateBinding Background}" CornerRadius="5"><ContentPresenter ContentSource="Header" RecognizesAccessKey="True"/></Border><ControlTemplate.Triggers><Trigger Property="IsHighlighted" Value="True"><Setter TargetName="root" Property="Background" Value="{DynamicResource ButtonHover}"/></Trigger><Trigger Property="IsEnabled" Value="False"><Setter TargetName="root" Property="Opacity" Value=".45"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Setter.Value></Setter>
  </Style>
  <Style x:Key="GameCardMenuSeparatorStyle" TargetType="Separator"><Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Separator"><Border Height="1" Margin="8,4" Background="{DynamicResource Border}"/></ControlTemplate></Setter.Value></Setter></Style>
</UserControl.Resources>
<ScrollViewer VerticalScrollBarVisibility="Auto"><StackPanel Margin="34,28,34,32"><TextBlock Foreground="{DynamicResource Text}" FontSize="30" FontWeight="Bold" Text="游戏库"/><TextBlock Margin="0,8,0,24" Foreground="{DynamicResource Muted}" Text="添加和管理需要保护的游戏。通过卡片右下角菜单管理存档或删除游戏。"/>
<Border Padding="24" Style="{StaticResource PanelStyle}"><StackPanel><TextBlock Foreground="{DynamicResource Text}" FontSize="18" FontWeight="SemiBold" Text="添加游戏"/><TextBlock Margin="0,8,0,16" Foreground="{DynamicResource Muted}" Text="使用统一向导导入平台游戏、选择本地启动入口，或手动创建游戏。"/><Button Width="140" Height="40" HorizontalAlignment="Left" Style="{StaticResource Primary}" Click="OpenAddGameWizardButton_OnClick" Content="＋ 添加游戏"/></StackPanel></Border>
<TextBlock Margin="0,26,0,14" Foreground="{DynamicResource Text}" FontSize="20" FontWeight="SemiBold" Text="已添加的游戏"/>
<ItemsControl MinHeight="230" ItemsSource="{Binding FilteredGames}">
  <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
  <ItemsControl.ItemTemplate><DataTemplate>
    <Grid Width="205" Height="245" Margin="0,0,16,16">
      <Border Style="{StaticResource PanelStyle}">
        <Grid>
          <Grid.RowDefinitions><RowDefinition Height="122"/><RowDefinition Height="83"/><RowDefinition Height="40"/></Grid.RowDefinitions>
          <Border CornerRadius="13,13,0,0"><Border.Background><LinearGradientBrush StartPoint="0,0" EndPoint="1,1"><GradientStop Color="#1A3C60"/><GradientStop Color="#172338" Offset=".6"/><GradientStop Color="#46354B" Offset="1"/></LinearGradientBrush></Border.Background><TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#6CACFF" FontSize="20" FontWeight="Bold" Text="{Binding Name}" TextTrimming="CharacterEllipsis"/></Border>
          <StackPanel Grid.Row="1" Margin="13,7,13,2">
            <TextBlock Foreground="{DynamicResource Text}" FontWeight="SemiBold" Text="{Binding Name}" TextTrimming="CharacterEllipsis"/>
            <TextBlock Margin="0,3,0,0" Foreground="{DynamicResource Muted}" FontSize="12" Text="{Binding Provider}"/>
            <TextBlock Margin="0,5,0,0" Foreground="{DynamicResource Muted}" FontSize="12"><TextBlock.Text><MultiBinding Converter="{StaticResource GameRuntimeStatusConverter}"><Binding/><Binding Path="DataContext" RelativeSource="{RelativeSource AncestorType=UserControl}"/><Binding Path="DataContext.RuntimeStatusVersion" RelativeSource="{RelativeSource AncestorType=UserControl}"/></MultiBinding></TextBlock.Text></TextBlock>
            <TextBlock Margin="0,3,0,0" Foreground="{DynamicResource Muted}" FontSize="12"><TextBlock.Text><MultiBinding Converter="{StaticResource GameProtectionStatusConverter}"><Binding/><Binding Path="DataContext" RelativeSource="{RelativeSource AncestorType=UserControl}"/><Binding Path="DataContext.RuntimeStatusVersion" RelativeSource="{RelativeSource AncestorType=UserControl}"/></MultiBinding></TextBlock.Text></TextBlock>
          </StackPanel>
        </Grid>
      </Border>
      <Button Style="{StaticResource GameCardButton}" Command="{Binding DataContext.SelectGameCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}"/>
      <StackPanel Margin="0,0,10,6" HorizontalAlignment="Right" VerticalAlignment="Bottom" Orientation="Horizontal">
        <Button Width="62" Height="28" Style="{StaticResource Primary}" Command="{Binding DataContext.LaunchGameCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Content="启动">
          <Button.ToolTip><MultiBinding Converter="{StaticResource GameLaunchDisabledReasonConverter}"><Binding/><Binding Path="DataContext" RelativeSource="{RelativeSource AncestorType=UserControl}"/><Binding Path="DataContext.RuntimeStatusVersion" RelativeSource="{RelativeSource AncestorType=UserControl}"/></MultiBinding></Button.ToolTip>
        </Button>
        <Button Width="30" Height="28" Margin="6,0,0,0" Padding="0" Style="{StaticResource ButtonStyle}" Tag="{Binding}" Click="GameMenuButton_OnClick" Content="⋮">
          <Button.ContextMenu>
            <ContextMenu Style="{StaticResource GameCardContextMenuStyle}" DataContext="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource Self}}">
              <MenuItem Header="存档管理" Style="{StaticResource GameCardMenuItemStyle}" Click="ManageSaveMenuItem_OnClick"/>
              <Separator Style="{StaticResource GameCardMenuSeparatorStyle}"/>
              <MenuItem Header="删除" Style="{StaticResource GameCardMenuItemStyle}" Click="DeleteGameMenuItem_OnClick"/>
            </ContextMenu>
          </Button.ContextMenu>
        </Button>
      </StackPanel>
    </Grid>
  </DataTemplate></ItemsControl.ItemTemplate>
</ItemsControl><Border Padding="16" Style="{StaticResource PanelStyle}"><TextBlock Foreground="{DynamicResource Muted}" Text="{Binding StatusText}" TextWrapping="Wrap"/></Border></StackPanel></ScrollViewer>
</UserControl>

<UserControl x:Class="GameSaveManager.App.Views.LibraryView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
<ScrollViewer VerticalScrollBarVisibility="Auto"><StackPanel Margin="34,28,34,32"><TextBlock Foreground="{DynamicResource Text}" FontSize="30" FontWeight="Bold" Text="游戏库"/><TextBlock Margin="0,8,0,24" Foreground="{DynamicResource Muted}" Text="扫描、添加、自动同步或删除需要保护的游戏。"/>
<Border Padding="24" Style="{StaticResource PanelStyle}"><StackPanel><TextBlock Foreground="{DynamicResource Text}" FontSize="18" FontWeight="SemiBold" Text="添加云端游戏"/><Grid Margin="0,16,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="14"/><ColumnDefinition Width="150"/></Grid.ColumnDefinitions><TextBox Style="{StaticResource Input}" Text="{Binding NewGameName, UpdateSourceTrigger=PropertyChanged}" ToolTip="游戏名称，同一账号下不可重复"/><Button Grid.Column="2" Style="{StaticResource Primary}" Command="{Binding CreateGameCommand}" Content="创建游戏"/></Grid><TextBlock Margin="0,8,0,0" Foreground="{DynamicResource Muted}" FontSize="12" Text="同一账号下游戏名称不能重复；客户端和服务端都会校验。"/><TextBlock Margin="0,20,0,8" Foreground="{DynamicResource Muted}" Text="发现本机安装的游戏"/><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="14"/><ColumnDefinition Width="150"/></Grid.ColumnDefinitions><ComboBox Height="40" Padding="10,4" ItemsSource="{Binding DiscoveredGames}" SelectedItem="{Binding SelectedDiscoveredGame}" DisplayMemberPath="Name"/><Button Grid.Column="2" Style="{StaticResource ButtonStyle}" Command="{Binding DiscoverGamesCommand}" Content="扫描本机游戏"/></Grid><TextBlock Margin="0,10,0,0" Foreground="{DynamicResource Muted}" FontSize="12" Text="已支持 Steam、Epic 和 GOG 安装信息扫描；存档路径仍应由你确认。"/></StackPanel></Border>
<TextBlock Margin="0,26,0,14" Foreground="{DynamicResource Text}" FontSize="20" FontWeight="SemiBold" Text="已添加的游戏"/>
<ItemsControl ItemsSource="{Binding FilteredGames}"><ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel><ItemsControl.ItemTemplate><DataTemplate><Button Width="235" Height="130" Margin="0,0,16,16" Background="Transparent" BorderThickness="0" Command="{Binding DataContext.SelectGameCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}"><Border Padding="18" Style="{StaticResource PanelStyle}"><StackPanel><TextBlock Foreground="{DynamicResource Text}" FontSize="18" FontWeight="SemiBold" Text="{Binding Name}" TextTrimming="CharacterEllipsis"/><TextBlock Margin="0,9,0,0" Foreground="{DynamicResource Muted}" Text="{Binding Provider}"/><TextBlock Margin="0,18,0,0" Foreground="{DynamicResource Success}" Text="● 点击配置同步"/></StackPanel></Border></Button></DataTemplate></ItemsControl.ItemTemplate></ItemsControl>
<Border Padding="20" Style="{StaticResource PanelStyle}"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Foreground="{DynamicResource Text}" FontSize="16" FontWeight="SemiBold" Text="删除所选游戏"/><TextBlock Margin="0,7,0,0" Foreground="{DynamicResource Muted}" Text="将删除该游戏的全部云端快照，并释放不再被引用的云端存档内容。本机原始存档文件不会删除。" TextWrapping="Wrap"/></StackPanel><Button Grid.Column="1" Margin="18,0,0,0" Style="{StaticResource ButtonStyle}" Foreground="#F87171" BorderBrush="#8F3340" Click="DeleteGameButton_OnClick" Content="删除游戏"/></Grid></Border>
<Border Margin="0,18,0,0" Padding="16" Style="{StaticResource PanelStyle}"><TextBlock Foreground="{DynamicResource Muted}" Text="{Binding StatusText}" TextWrapping="Wrap"/></Border></StackPanel></ScrollViewer>
</UserControl>
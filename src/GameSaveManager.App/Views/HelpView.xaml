<UserControl x:Class="GameSaveManager.App.Views.HelpView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
<ScrollViewer VerticalScrollBarVisibility="Auto"><StackPanel Margin="34,28,34,32"><TextBlock Foreground="White" FontSize="30" FontWeight="Bold" Text="使用说明"/><TextBlock Margin="0,8,0,26" Foreground="{StaticResource Muted}" Text="从添加游戏到安全恢复，只需要完成以下步骤。"/>
<Border Padding="26" Style="{StaticResource PanelStyle}"><StackPanel><TextBlock Foreground="#55ABFF" FontSize="15" FontWeight="SemiBold" Text="第一步"/><TextBlock Margin="0,8,0,0" Foreground="White" FontSize="21" FontWeight="SemiBold" Text="添加需要管理的游戏"/><TextBlock Margin="0,8,0,0" Foreground="#A0B2C8" TextWrapping="Wrap" Text="进入“游戏库”，扫描 Steam、Epic、GOG 的安装信息，或直接输入游戏名称创建云端游戏。"/><Separator Margin="0,22" Background="#2A3D55"/><TextBlock Foreground="#55ABFF" FontSize="15" FontWeight="SemiBold" Text="第二步"/><TextBlock Margin="0,8,0,0" Foreground="White" FontSize="21" FontWeight="SemiBold" Text="配置真实存档目录"/><TextBlock Margin="0,8,0,0" Foreground="#A0B2C8" TextWrapping="Wrap" Text="进入“同步中心”，选择游戏并填写存档目录。系统会使用 SQLite Hash Cache 加速后续扫描。"/><Separator Margin="0,22" Background="#2A3D55"/><TextBlock Foreground="#55ABFF" FontSize="15" FontWeight="SemiBold" Text="第三步"/><TextBlock Margin="0,8,0,0" Foreground="White" FontSize="21" FontWeight="SemiBold" Text="同步、恢复与冲突处理"/><TextBlock Margin="0,8,0,0" Foreground="#A0B2C8" TextWrapping="Wrap" Text="手动同步会创建不可变快照。恢复时先下载并校验对象，再保留当前存档的安全备份。两台设备同时修改时，在时间线选择“冲突时保留本机版本”，两个版本都会被保留。"/></StackPanel></Border>
<Grid Margin="0,22,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="16"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><Border Padding="20" Style="{StaticResource PanelStyle}"><StackPanel><TextBlock Foreground="White" FontSize="18" FontWeight="SemiBold" Text="常见问题"/><TextBlock Margin="0,12,0,0" Foreground="#A0B2C8" TextWrapping="Wrap" Text="为什么不能直接删除存档？恢复采用 staging 目录和校验流程，避免文件复制中断造成损坏。"/></StackPanel></Border><Border Grid.Column="2" Padding="20" Style="{StaticResource PanelStyle}"><StackPanel><TextBlock Foreground="White" FontSize="18" FontWeight="SemiBold" Text="下一步"/><Button Margin="0,12,0,0" Style="{StaticResource Primary}" Command="{Binding NavigateCommand}" CommandParameter="游戏库" Content="添加第一款游戏"/></StackPanel></Border></Grid></StackPanel></ScrollViewer>
</UserControl>